<div class="container container--narrow" style="padding-top: var(--space-120); padding-bottom: var(--space-120); text-align: center;">
  <h1 style="margin-bottom: var(--space-24);">Reset Your Password</h1>
  <p style="color: var(--text-secondary); margin-bottom: var(--space-64);">Enter a new password for {{ email }}</p>
  
  <div style="max-width: 400px; margin: 0 auto; text-align: left;">
    {% form 'reset_customer_password' %}
      {{ form.errors | default_errors }}
      
      <div style="margin-bottom: var(--space-24);">
        <input type="password" name="customer[password]" placeholder="New Password" required style="width: 100%; padding: var(--space-16); background: transparent; border: 1px solid var(--border-subtle); color: var(--text-primary);">
      </div>
      
      <div style="margin-bottom: var(--space-32);">
        <input type="password" name="customer[password_confirmation]" placeholder="Confirm New Password" required style="width: 100%; padding: var(--space-16); background: transparent; border: 1px solid var(--border-subtle); color: var(--text-primary);">
      </div>
      
      <button type="submit" class="btn-primary" style="width: 100%;">Reset Password</button>
    {% endform %}
  </div>
</div>
