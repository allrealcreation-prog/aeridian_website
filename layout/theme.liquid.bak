<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary_obsidian }}">
    <link rel="canonical" href="{{ canonical_url }}">
    
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {% render 'seo-tags' %}

    <!-- Phase 15: Network Optimization -->
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="{{ 'Mexon.woff2' | asset_url }}" as="font" type="font/woff2" crossorigin>

    <!-- Phase 15: Critical CSS -->
    <style id="AeridianCritical">
      /* 1. Theme Tokens (Base) */
      :root {
        --bg-primary: #111111;
        --bg-secondary: #1a1a1a;
        --text-primary: #ffffff;
        --text-secondary: rgba(255, 255, 255, 0.6);
        --accent-color: #00FFD1;
        --glow-color: rgba(0, 255, 209, 0.1);
        --border-subtle: rgba(255, 255, 255, 0.1);
        --font-body-base: 14px;
        --space-16: 16px;
        --space-24: 24px;
      }
      
      /* Theme Mode Overrides (Handled inline by theme-provider) */
      html[data-theme="light"] {
        --bg-primary: #EEEEEE;
        --bg-secondary: #FFFFFF;
        --text-primary: #111111;
        --text-secondary: rgba(0, 0, 0, 0.6);
        --border-subtle: rgba(0, 0, 0, 0.1);
        --glow-color: rgba(0, 255, 209, 0.2);
      }

      /* 2. Reset */
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; width: 100%; min-height: 100vh; background-color: var(--bg-primary); color: var(--text-primary); font-family: var(--font-body); -webkit-font-smoothing: antialiased; }
      
      /* 3. Typography Base */
      h1, h2, h3, p { margin: 0; padding: 0; }
      a { text-decoration: none; color: inherit; }

      /* 4. Header Skeleton */
      .site-header { position: fixed; top: 0; width: 100%; height: 80px; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; z-index: 100; background: var(--bg-primary); border-bottom: 1px solid var(--border-subtle); }
      .header-logo { font-size: 24px; font-weight: bold; letter-spacing: 0.1em; }
      
      /* 5. Hero Skeleton */
      .hero-cinematic { width: 100%; height: 100vh; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
      .hero-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
      .hero-content { position: relative; z-index: 2; text-align: center; }

      /* 6. PDP Above Fold Skeleton */
      .pdp-main { width: 100%; min-height: 100vh; padding: 80px 24px; }
      .pdp-layout { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 64px; }
      @media (max-width: 1024px) { .pdp-layout { grid-template-columns: 1fr; gap: 32px; } }
    </style>

    {{ content_for_header }}

    <!-- Phase 11: Global Theme Engine -->
    {% render 'theme-provider' %}
    
    <!-- Phase 15: Deferred Non-Critical CSS -->
    <link rel="stylesheet" href="{{ 'theme-tokens.css' | asset_url }}" media="print" onload="this.media='all'">
    
    <!-- Phase 12: Global Motion Engine -->
    <link rel="stylesheet" href="{{ 'motion-tokens.css' | asset_url }}" media="print" onload="this.media='all'">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" defer></script>
    
    {%- comment -%}
      CSS variables generation based on schema settings
    {%- endcomment -%}
    {%- liquid
      assign font_primary = settings.font_primary
      assign font_fallback = settings.font_fallback
    -%}
    
    <style>
      :root {
        --color-primary-obsidian: {{ settings.color_primary_obsidian }};
        --color-primary-carbon: {{ settings.color_primary_carbon }};
        --color-primary-pure-white: {{ settings.color_primary_pure_white }};
        --color-primary-soft-white: {{ settings.color_primary_soft_white }};
        --color-secondary-titanium: {{ settings.color_secondary_titanium }};
        --color-secondary-steel: {{ settings.color_secondary_steel }};
        --color-accent-atmospheric: {{ settings.color_accent_atmospheric }};

        --font-display: 'Mexon', sans-serif;
        --font-body: 'Inter', sans-serif;

        --radius-sm: {{ settings.radius_sm }}px;
        --radius-md: {{ settings.radius_md }}px;
        --radius-lg: {{ settings.radius_lg }}px;
      }
    </style>

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    
    <style>
      /* Prevent scrolling while loading */
      body.is-loading {
        overflow: hidden;
      }
    </style>

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    </script>
    
    <!-- GSAP & ScrollTrigger -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" defer></script>
  </head>

  <body class="template-{{ template.name | handle }} is-loading">
    {% section 'loading-screen' %}
    <!-- Phase 12: Global Motion Elements -->
    <div id="GlobalTransitionOverlay" class="is-active"></div>
    <div id="ScrollProgressBar"></div>
    <div id="CustomCursor"></div>

    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      Skip to content
    </a>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    <!-- Phase 8: Global Footer -->
    {% section 'footer' %}

    <!-- Phase 6 Global Snippets -->
    {% render 'quick-view-modal' %}
    {% render 'filter-panel' %}
    {% render 'wishlist-auth-logic' %}
    
    <!-- Phase 11 Theme Engine Controller -->
    <script src="{{ 'theme-engine.js' | asset_url }}" defer="defer"></script>
    
    <!-- Phase 12 Motion Engine Controller -->
    <script>
      window.AeridianSettings = window.AeridianSettings || {};
      window.AeridianSettings.enableCursor = {{ settings.enable_custom_cursor | default: true | json }};
      window.AeridianSettings.enableMagnetic = {{ settings.enable_magnetic_buttons | default: true | json }};
      window.AeridianSettings.enablePageTransitions = {{ settings.enable_page_transitions | default: true | json }};
      window.AeridianSettings.enableScrollProgress = {{ settings.enable_scroll_progress | default: true | json }};
    </script>
    <script src="{{ 'motion-engine.js' | asset_url }}" defer="defer"></script>

    <!-- Phase 15 Conditional Script Loading -->
    {%- if template.name == 'collection' -%}
      <script src="{{ 'collection-filters.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    {%- if template.name == 'product' -%}
      <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
  </body>
</html>
