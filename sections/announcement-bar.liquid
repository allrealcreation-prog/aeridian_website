{%- if section.settings.show_announcement -%}
  <style>
    .announcement-bar {
      background-color: var(--color-primary-carbon);
      color: var(--color-primary-soft-white);
      text-align: center;
      padding: var(--space-8) var(--space-24);
      min-height: 36px;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      z-index: 100;
      transition: height var(--duration-base) var(--ease-luxury), opacity var(--duration-base) var(--ease-luxury);
    }

    .announcement-bar__text {
      font-size: var(--font-caption);
      letter-spacing: var(--tracking-caption);
      text-transform: uppercase;
      font-weight: 500;
      margin: 0;
    }

    .announcement-bar__close {
      position: absolute;
      right: var(--space-16);
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: var(--color-secondary-titanium);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-4);
      transition: color var(--duration-fast) var(--ease-luxury);
    }

    .announcement-bar__close:hover {
      color: var(--color-primary-pure-white);
    }

    .announcement-bar__close svg {
      width: 12px;
      height: 12px;
    }

    /* Hidden state */
    .announcement-bar.is-hidden {
      height: 0;
      min-height: 0;
      padding-top: 0;
      padding-bottom: 0;
      opacity: 0;
      overflow: hidden;
      pointer-events: none;
    }
  </style>

  <div id="AnnouncementBar-{{ section.id }}" class="announcement-bar" role="region" aria-label="Announcement">
    <p class="announcement-bar__text">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
      {%- else -%}
        {{ section.settings.text }}
      {%- endif -%}
    </p>

    {%- if section.settings.dismissible -%}
      <button type="button" class="announcement-bar__close" aria-label="Dismiss announcement" onclick="dismissAnnouncement('{{ section.id }}')">
        <svg aria-hidden="true" focusable="false" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    {%- endif -%}
  </div>

  <script>
    function dismissAnnouncement(id) {
      const bar = document.getElementById('AnnouncementBar-' + id);
      if(bar) {
        bar.classList.add('is-hidden');
        sessionStorage.setItem('aeridian_announcement_' + id, 'dismissed');
      }
    }

    // Check on load
    (function() {
      if (sessionStorage.getItem('aeridian_announcement_{{ section.id }}') === 'dismissed') {
        const bar = document.getElementById('AnnouncementBar-{{ section.id }}');
        if(bar) bar.style.display = 'none';
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "FW26 COLLECTION NOW AVAILABLE"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "dismissible",
      "label": "Allow users to dismiss",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
