<style>
  .featured-products {
    position: relative;
    background-color: var(--color-primary-obsidian);
    color: var(--color-primary-pure-white);
    padding-bottom: var(--space-120);
  }

  /* Intro Section (80vh) */
  .fp-intro {
    height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 var(--space-24);
    background: radial-gradient(circle at center, rgba(127, 217, 255, 0.05) 0%, transparent 60%);
  }

  html[data-theme="light"] .fp-intro {
    background: radial-gradient(circle at center, rgba(127, 217, 255, 0.1) 0%, transparent 60%);
  }

  .fp-intro__label {
    font-size: var(--font-caption);
    letter-spacing: var(--tracking-caption);
    text-transform: uppercase;
    color: var(--color-secondary-titanium);
    margin-bottom: var(--space-24);
  }

  .fp-intro__headline {
    font-size: var(--font-display-l);
    line-height: 1.1;
    margin-bottom: var(--space-32);
    max-width: 900px;
  }

  .fp-intro__sub {
    font-size: var(--font-body-large);
    color: var(--color-primary-soft-white);
    max-width: 500px;
    margin-bottom: var(--space-48);
  }

  /* Grid System */
  .fp-grid-wrapper {
    max-width: var(--container-large);
    margin: 0 auto;
    padding: 0 var(--space-24);
    perspective: 1000px; /* For 3D Tilt */
  }

  .fp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-32);
  }

  /* Product Card (Glassmorphic) */
  .product-card {
    position: relative;
    background: rgba(17, 17, 17, 0.4);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-sm);
    padding: var(--space-16);
    display: flex;
    flex-direction: column;
    transition: transform var(--duration-fast), border-color var(--duration-fast), box-shadow var(--duration-fast);
    transform-style: preserve-3d;
  }

  html[data-theme="light"] .product-card {
    background: rgba(255, 255, 255, 0.6);
    border-color: rgba(0, 0, 0, 0.05);
  }

  .product-card:hover {
    border-color: rgba(127, 217, 255, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  html[data-theme="light"] .product-card:hover {
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
  }

  .product-card__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4/5;
    border-radius: calc(var(--radius-sm) - 4px);
    overflow: hidden;
    margin-bottom: var(--space-16);
    background-color: var(--color-primary-carbon);
    transform: translateZ(20px); /* 3D pop */
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-luxury);
  }

  .product-card:hover .product-card__image {
    transform: scale(1.08);
  }

  .product-card__info {
    transform: translateZ(10px); /* 3D pop */
  }

  .product-card__vendor {
    font-size: var(--font-caption);
    color: var(--color-secondary-titanium);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .product-card__title {
    font-size: var(--font-body-regular);
    font-weight: 500;
    margin-bottom: var(--space-8);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-card__price {
    font-size: var(--font-body-regular);
    color: var(--color-accent-atmospheric);
  }

  /* Quick Actions (Hover Reveal) */
  .product-card__actions {
    position: absolute;
    bottom: var(--space-16);
    left: var(--space-16);
    right: var(--space-16);
    display: flex;
    gap: var(--space-8);
    opacity: 0;
    transform: translateY(10px) translateZ(30px);
    transition: opacity var(--duration-fast), transform var(--duration-fast);
  }

  .product-card:hover .product-card__actions {
    opacity: 1;
    transform: translateY(0) translateZ(30px);
  }

  .btn-quick-action {
    flex: 1;
    padding: var(--space-12) 0;
    background: var(--color-primary-pure-white);
    color: var(--color-primary-obsidian);
    text-align: center;
    border: none;
    border-radius: var(--radius-sm);
    font-size: var(--font-caption);
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
  }

  .btn-icon-action {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-carbon);
    color: var(--color-primary-pure-white);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  html[data-theme="light"] .btn-icon-action {
    background: var(--bg-primary);
    color: var(--color-primary-obsidian);
    border-color: rgba(0, 0, 0, 0.1);
  }

  @media screen and (max-width: 1024px) {
    .fp-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-16); }
  }

  @media screen and (max-width: 767px) {
    .fp-intro { height: 60vh; }
    .fp-grid { grid-template-columns: 1fr; }
    .product-card__actions { opacity: 1; transform: translateY(0); position: relative; bottom: auto; left: auto; right: auto; margin-top: var(--space-16); }
  }
</style>

<section class="featured-products" data-section-id="{{ section.id }}">
  <div class="fp-intro" id="FPIntro">
    <div class="fp-intro__label">{{ section.settings.label }}</div>
    <h2 class="fp-intro__headline">{{ section.settings.headline }}</h2>
    <p class="fp-intro__sub">{{ section.settings.description }}</p>
    <a href="{{ section.settings.collection.url | default: '#' }}" class="btn-primary">Explore All Products</a>
  </div>

  <div class="fp-grid-wrapper">
    <div class="fp-grid">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: section.settings.product_limit -%}
          <div class="product-card js-tilt-card" data-handle="{{ product.handle }}">
            <a href="{{ product.url }}" class="product-card__image-wrap">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" class="product-card__image" loading="lazy">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'product-card__image' }}
              {%- endif -%}
            </a>
            <div class="product-card__info">
              <div class="product-card__vendor">{{ product.vendor }}</div>
              <h3 class="product-card__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              <div class="product-card__price">{{ product.price | money }}</div>
            </div>
            <div class="product-card__actions">
              <button class="btn-quick-action" onclick="openQuickView('{{ product.handle }}')">Quick View</button>
              <button class="btn-icon-action js-wishlist-toggle" data-handle="{{ product.handle }}" aria-label="Add to Wishlist">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback if no collection selected -->
        {%- for i in (1..8) -%}
          <div class="product-card js-tilt-card">
            <div class="product-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'product-card__image' }}
            </div>
            <div class="product-card__info">
              <div class="product-card__vendor">AERIDIAN</div>
              <h3 class="product-card__title">Future Shell Jacket 0{{ i }}</h3>
              <div class="product-card__price">$350.00</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  // GSAP Intro Reveal
  if(typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    gsap.fromTo("#FPIntro", {
      opacity: 0.2,
      y: 50
    }, {
      opacity: 1,
      y: 0,
      scrollTrigger: {
        trigger: "#FPIntro",
        start: "top 80%",
        end: "center center",
        scrub: true
      }
    });
  }

  // 3D Glassmorphic Tilt Logic
  const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(!isReducedMotion && window.innerWidth > 1024) {
    const cards = document.querySelectorAll('.js-tilt-card');
    
    cards.forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        // Calculate rotation based on cursor position (-10 to 10 degrees)
        const xPct = (x / rect.width) - 0.5;
        const yPct = (y / rect.height) - 0.5;
        
        const rotateY = xPct * 20;
        const rotateX = -yPct * 20;
        
        card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      });
      
      card.addEventListener('mouseleave', () => {
        card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg)`;
      });
    });
  }
});
</script>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Micro Label",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Designed To Be Worn.\nBuilt To Be Remembered."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Future-inspired apparel created for people who refuse ordinary."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 4,
      "max": 16,
      "step": 4,
      "label": "Product Limit",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Featured Products Grid"
    }
  ]
}
{% endschema %}
