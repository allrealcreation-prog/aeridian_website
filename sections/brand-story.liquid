<style>
  /* ==========================================
     GLOBAL BRAND STORY STYLES
     ========================================== */
  .brand-story {
    position: relative;
    background-color: var(--color-primary-obsidian);
    color: var(--color-primary-pure-white);
    overflow: hidden;
  }

  html[data-theme="light"] .brand-story {
    background-color: var(--bg-primary);
    color: var(--text-primary);
  }

  /* Utility */
  .bs-section-title {
    font-size: var(--font-caption);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-secondary-titanium);
    margin-bottom: var(--space-24);
  }

  /* ==========================================
     PART 1: BRAND INTRO (120vh)
     ========================================== */
  .bs-intro {
    height: 120vh;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    position: relative;
    padding: 0 var(--space-24);
  }

  .bs-intro__text-mask {
    overflow: hidden;
    line-height: 1.1;
  }

  .bs-intro__headline {
    font-size: var(--font-display-xl);
    text-transform: uppercase;
    margin: 0;
    transform: translateY(100%);
  }

  .bs-intro__sub {
    font-size: var(--font-body-large);
    max-width: 600px;
    margin: var(--space-32) auto 0 auto;
    opacity: 0;
  }

  /* ==========================================
     PART 2: THE ORIGIN (150vh)
     ========================================== */
  .bs-origin {
    height: 150vh;
    position: relative;
  }

  .bs-origin__pin {
    height: 100vh;
    position: sticky;
    top: 0;
    display: flex;
    max-width: var(--container-large);
    margin: 0 auto;
    padding: 0 var(--space-24);
    align-items: center;
  }

  .bs-origin__left {
    width: 50%;
    padding-right: var(--space-64);
  }

  .bs-origin__p {
    font-size: var(--font-heading-2);
    margin-bottom: var(--space-24);
    opacity: 0.2;
    transition: opacity var(--duration-base);
  }

  .bs-origin__p.is-active {
    opacity: 1;
  }

  .bs-origin__right {
    width: 50%;
    height: 60vh;
    position: relative;
    perspective: 1000px;
  }

  .bs-origin__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-sm);
    opacity: 0;
    transform: translateZ(-100px);
    transition: all var(--duration-reveal) var(--ease-luxury);
  }

  .bs-origin__image.is-active {
    opacity: 1;
    transform: translateZ(0);
  }

  /* ==========================================
     PART 3: THE PHILOSOPHY (180vh)
     ========================================== */
  .bs-philosophy {
    height: 180vh;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .bs-philosophy__pin {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .bs-philosophy__word {
    font-size: clamp(4rem, 12vw, 15rem);
    text-transform: uppercase;
    font-weight: bold;
    line-height: 1;
    letter-spacing: -0.02em;
    position: absolute;
    opacity: 0;
    transform: scale(0.8) translateY(50px);
  }

  /* ==========================================
     PART 4: CREATIVE PROCESS (160vh)
     ========================================== */
  .bs-process {
    height: 160vh;
    position: relative;
  }

  .bs-process__pin {
    height: 100vh;
    position: sticky;
    top: 0;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .bs-process__track {
    display: flex;
    gap: 15vw;
    padding: 0 50vw;
  }

  .bs-process__node {
    flex-shrink: 0;
    text-align: center;
    position: relative;
  }

  .bs-process__number {
    font-size: var(--font-caption);
    color: var(--color-accent-atmospheric);
    margin-bottom: var(--space-8);
  }

  .bs-process__title {
    font-size: var(--font-heading-2);
  }

  /* ==========================================
     PART 5: COLLECTION UNIVERSE (180vh)
     ========================================== */
  .bs-universe {
    height: 180vh;
    position: relative;
    background: radial-gradient(circle at center, rgba(127, 217, 255, 0.05) 0%, transparent 70%);
  }
  
  html[data-theme="light"] .bs-universe {
    background: radial-gradient(circle at center, rgba(127, 217, 255, 0.1) 0%, transparent 70%);
  }

  .bs-universe__pin {
    height: 100vh;
    position: sticky;
    top: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    perspective: 1000px;
    overflow: hidden;
  }

  .bs-orbit-center {
    font-size: var(--font-heading-1);
    font-weight: bold;
    z-index: 10;
  }

  .bs-orbit-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform-style: preserve-3d;
    border-radius: 50%;
    border: 1px dashed rgba(255,255,255,0.1);
  }

  html[data-theme="light"] .bs-orbit-ring {
    border-color: rgba(0,0,0,0.1);
  }

  .bs-orbit-item {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%) translateY(-50%);
    background: var(--color-primary-carbon);
    padding: var(--space-8) var(--space-16);
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255,255,255,0.1);
    font-size: var(--font-caption);
    white-space: nowrap;
  }

  html[data-theme="light"] .bs-orbit-item {
    background: var(--bg-primary);
    border-color: rgba(0,0,0,0.1);
  }

  /* ==========================================
     PART 6: FUTURE VISION (140vh)
     ========================================== */
  .bs-future {
    height: 140vh;
    position: relative;
  }

  .bs-future__pin {
    height: 100vh;
    position: sticky;
    top: 0;
    overflow: hidden;
  }

  #FutureCanvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .bs-future__text {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    font-size: var(--font-display-l);
    pointer-events: none;
  }

  /* ==========================================
     PART 7: BRAND MANIFESTO (200vh)
     ========================================== */
  .bs-manifesto {
    height: 200vh;
    position: relative;
  }

  .bs-manifesto__pin {
    height: 100vh;
    position: sticky;
    top: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 var(--space-24);
  }

  .bs-manifesto__sentence {
    position: absolute;
    font-size: var(--font-heading-1);
    max-width: 900px;
    opacity: 0;
    transform: scale(0.9);
  }

  /* ==========================================
     PART 8: COMMUNITY SIGNALS (100vh)
     ========================================== */
  .bs-community {
    padding: var(--space-120) var(--space-24);
    max-width: var(--container-large);
    margin: 0 auto;
    text-align: center;
  }

  .bs-signals-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
    margin-top: var(--space-64);
  }

  .bs-signal {
    background: rgba(17, 17, 17, 0.4);
    backdrop-filter: blur(12px);
    border: var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: var(--space-48) var(--space-24);
  }

  html[data-theme="light"] .bs-signal {
    background: rgba(255, 255, 255, 0.6);
  }

  .bs-signal__number {
    font-size: var(--font-display-l);
    color: var(--color-accent-atmospheric);
    margin-bottom: var(--space-8);
  }

  /* ==========================================
     PART 9: QUOTE WALL (120vh)
     ========================================== */
  .bs-quote-wall {
    height: 120vh;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: var(--space-120);
  }

  .bs-quote {
    font-size: clamp(3rem, 8vw, 8rem);
    text-transform: uppercase;
    white-space: nowrap;
    opacity: 0.1;
    line-height: 1;
    font-weight: bold;
  }

  /* Transition Signal */
  .bs-transition-signal {
    position: absolute;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 100px;
    background: linear-gradient(to bottom, var(--color-accent-atmospheric), transparent);
    animation: pulseSignal 2s infinite;
  }

  @keyframes pulseSignal {
    0% { height: 0; opacity: 1; }
    100% { height: 100px; opacity: 0; transform: translateX(-50%) translateY(50px); }
  }

  /* Mobile Responses */
  @media screen and (max-width: 1024px) {
    .bs-origin__pin { flex-direction: column; justify-content: center; }
    .bs-origin__left, .bs-origin__right { width: 100%; }
    .bs-origin__right { height: 40vh; margin-top: var(--space-32); }
    .bs-signals-grid { grid-template-columns: 1fr; }
  }
</style>

<section class="brand-story" data-section-id="{{ section.id }}">
  
  <!-- PART 1: INTRO -->
  <div class="bs-intro" id="BSIntro">
    <div>
      <div class="bs-section-title">About AERIDIAN</div>
      <div class="bs-intro__text-mask">
        <h2 class="bs-intro__headline" id="BSIntroH1">Always New</h2>
      </div>
      <div class="bs-intro__text-mask">
        <h2 class="bs-intro__headline" id="BSIntroH2">To The World</h2>
      </div>
      <p class="bs-intro__sub" id="BSIntroSub">AERIDIAN is a premium graphic apparel brand built around constant discovery, creativity and evolution.</p>
    </div>
  </div>

  <!-- PART 2: THE ORIGIN -->
  <div class="bs-origin" id="BSOrigin">
    <div class="bs-origin__pin">
      <div class="bs-origin__left">
        <div class="bs-section-title">The Origin</div>
        <p class="bs-origin__p" id="OP1">The world moves fast. Ideas appear and disappear.</p>
        <p class="bs-origin__p" id="OP2">Most brands chase trends. We do not follow culture.</p>
        <p class="bs-origin__p" id="OP3">We explore it. We are built for those who never stop becoming.</p>
      </div>
      <div class="bs-origin__right">
        {%- if section.settings.origin_image_1 != blank -%}
          <img src="{{ section.settings.origin_image_1 | image_url: width: 800 }}" class="bs-origin__image" id="OI1" width="{{ section.settings.origin_image_1.width }}" height="{{ section.settings.origin_image_1.height }}">
          <img src="{{ section.settings.origin_image_2 | image_url: width: 800 }}" class="bs-origin__image" id="OI2" width="{{ section.settings.origin_image_2.width }}" height="{{ section.settings.origin_image_2.height }}">
          <img src="{{ section.settings.origin_image_3 | image_url: width: 800 }}" class="bs-origin__image" id="OI3" width="{{ section.settings.origin_image_3.width }}" height="{{ section.settings.origin_image_3.height }}">
        {%- else -%}
          <div class="bs-origin__image is-active" id="OI1">{{ 'lifestyle-1' | placeholder_svg_tag }}</div>
          <div class="bs-origin__image" id="OI2">{{ 'lifestyle-2' | placeholder_svg_tag }}</div>
          <div class="bs-origin__image" id="OI3">{{ 'lifestyle-1' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- PART 3: THE PHILOSOPHY -->
  <div class="bs-philosophy" id="BSPhilosophy">
    <div class="bs-philosophy__pin">
      <div class="bs-section-title" style="position: absolute; top: 10vh;">The Philosophy</div>
      <div class="bs-philosophy__word" id="Phil1">Discovery</div>
      <div class="bs-philosophy__word" id="Phil2">Creativity</div>
      <div class="bs-philosophy__word" id="Phil3">Expression</div>
      <div class="bs-philosophy__word" id="Phil4">Culture</div>
      <div class="bs-philosophy__word" id="Phil5">Future</div>
    </div>
  </div>

  <!-- PART 4: THE CREATIVE PROCESS -->
  <div class="bs-process" id="BSProcess">
    <div class="bs-process__pin">
      <div class="bs-process__track" id="BSProcessTrack">
        <div class="bs-process__node"><div class="bs-process__number">01</div><div class="bs-process__title">Observation</div></div>
        <div class="bs-process__node"><div class="bs-process__number">02</div><div class="bs-process__title">Exploration</div></div>
        <div class="bs-process__node"><div class="bs-process__number">03</div><div class="bs-process__title">Concept</div></div>
        <div class="bs-process__node"><div class="bs-process__number">04</div><div class="bs-process__title">Design</div></div>
        <div class="bs-process__node"><div class="bs-process__number">05</div><div class="bs-process__title">Creation</div></div>
        <div class="bs-process__node"><div class="bs-process__number">06</div><div class="bs-process__title">Release</div></div>
      </div>
    </div>
  </div>

  <!-- PART 5: THE COLLECTION UNIVERSE (CSS 3D) -->
  <div class="bs-universe" id="BSUniverse">
    <div class="bs-universe__pin">
      <div class="bs-section-title" style="position: absolute; top: 10vh;">The Categories Universe</div>
      <div class="bs-orbit-center">
        <div style="width: 200px;">
          {% render 'icon-wordmark' %}
        </div>
      </div>
      
      <div class="bs-orbit-ring" style="width: 400px; height: 400px; margin-left: -200px; margin-top: -200px;" id="Orbit1">
        <div class="bs-orbit-item" style="transform: rotate(0deg) translateX(200px) rotate(0deg);">Retro & Vintage</div>
        <div class="bs-orbit-item" style="transform: rotate(180deg) translateX(200px) rotate(-180deg);">Pop Culture</div>
      </div>
      
      <div class="bs-orbit-ring" style="width: 600px; height: 600px; margin-left: -300px; margin-top: -300px;" id="Orbit2">
        <div class="bs-orbit-item" style="transform: rotate(90deg) translateX(300px) rotate(-90deg);">Art & Design</div>
        <div class="bs-orbit-item" style="transform: rotate(270deg) translateX(300px) rotate(-270deg);">Nature & Travel</div>
      </div>

    </div>
  </div>

  <!-- PART 6: FUTURE VISION (Three.js) -->
  <div class="bs-future" id="BSFuture">
    <div class="bs-future__pin">
      <div class="bs-future__text">
        <div style="text-align: center;">
          <div class="bs-section-title">The Vision</div>
          <h2>The Future Is<br>Never Finished.</h2>
        </div>
      </div>
    </div>
  </div>

  <!-- PART 7: BRAND MANIFESTO -->
  <div class="bs-manifesto" id="BSManifesto">
    <div class="bs-manifesto__pin">
      <div class="bs-manifesto__sentence" id="Man1">We believe curiosity creates culture.</div>
      <div class="bs-manifesto__sentence" id="Man2">We believe creativity should move.</div>
      <div class="bs-manifesto__sentence" id="Man3">We believe every generation deserves new ideas.</div>
      <div class="bs-manifesto__sentence" id="Man4" style="color: var(--color-accent-atmospheric);">We are AERIDIAN.</div>
    </div>
  </div>

  <!-- PART 8: COMMUNITY SIGNALS -->
  <div class="bs-community" id="BSCommunity">
    <div class="bs-section-title">Community Signals</div>
    <div class="bs-signals-grid">
      <div class="bs-signal">
        <div class="bs-signal__number" data-target="150">0</div>
        <div>Products Released</div>
      </div>
      <div class="bs-signal">
        <div class="bs-signal__number" data-target="25">0</div>
        <div>Collections Created</div>
      </div>
      <div class="bs-signal">
        <div class="bs-signal__number" data-target="80">0</div>
        <div>Countries Reached</div>
      </div>
    </div>
  </div>

  <!-- PART 9: QUOTE WALL & OUTRO -->
  <div class="bs-quote-wall" id="BSQuoteWall">
    <div class="bs-quote" id="Quote1" style="transform: translateX(10%);">Always becoming.</div>
    <div class="bs-quote" id="Quote2" style="transform: translateX(-20%); text-align: right;">Always discovering.</div>
    <div class="bs-quote" id="Quote3" style="transform: translateX(5%);">Always creating.</div>
    
    <div class="bs-transition-signal"></div>
  </div>

</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  if(typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    
    if(!isReducedMotion) {
      // 1. Intro
      gsap.to(["#BSIntroH1", "#BSIntroH2"], {
        y: 0,
        duration: 1,
        stagger: 0.2,
        ease: "power3.out",
        scrollTrigger: { trigger: "#BSIntro", start: "top 80%" }
      });
      gsap.to("#BSIntroSub", { opacity: 1, duration: 1, delay: 0.5, scrollTrigger: { trigger: "#BSIntro", start: "top 80%" } });

      // 2. The Origin
      const originTl = gsap.timeline({ scrollTrigger: { trigger: "#BSOrigin", start: "top top", end: "bottom bottom", scrub: true } });
      originTl.to("#OP1", { opacity: 1, duration: 1 })
              .to("#OI1", { opacity: 1, z: 0, duration: 1 }, "<")
              .to("#OP1", { opacity: 0.2, duration: 1 })
              .to("#OP2", { opacity: 1, duration: 1 }, "<")
              .to("#OI2", { opacity: 1, z: 0, duration: 1 }, "<")
              .to("#OP2", { opacity: 0.2, duration: 1 })
              .to("#OP3", { opacity: 1, duration: 1 }, "<")
              .to("#OI3", { opacity: 1, z: 0, duration: 1 }, "<");

      // 3. The Philosophy
      const philTl = gsap.timeline({ scrollTrigger: { trigger: "#BSPhilosophy", start: "top top", end: "bottom bottom", scrub: true } });
      ["#Phil1", "#Phil2", "#Phil3", "#Phil4", "#Phil5"].forEach((id, index) => {
        philTl.to(id, { opacity: 1, scale: 1, y: 0, duration: 1 })
              .to(id, { opacity: 0, scale: 1.2, y: -50, duration: 1 });
      });

      // 4. Creative Process (Horizontal Scroll)
      const track = document.getElementById('BSProcessTrack');
      gsap.to(track, {
        x: () => -(track.scrollWidth - window.innerWidth),
        ease: "none",
        scrollTrigger: { trigger: "#BSProcess", start: "top top", end: "bottom bottom", scrub: true }
      });

      // 5. CSS Orbital Universe
      gsap.to("#Orbit1", {
        rotationZ: 360,
        ease: "none",
        scrollTrigger: { trigger: "#BSUniverse", start: "top bottom", end: "bottom top", scrub: 1 }
      });
      gsap.to("#Orbit2", {
        rotationZ: -360,
        ease: "none",
        scrollTrigger: { trigger: "#BSUniverse", start: "top bottom", end: "bottom top", scrub: 1.5 }
      });

      // 7. Brand Manifesto
      const manTl = gsap.timeline({ scrollTrigger: { trigger: "#BSManifesto", start: "top top", end: "bottom bottom", scrub: true } });
      ["#Man1", "#Man2", "#Man3", "#Man4"].forEach((id) => {
        manTl.to(id, { opacity: 1, scale: 1, duration: 1 })
             .to(id, { opacity: 0, scale: 1.1, duration: 1 });
      });

      // 8. Community Signals (Counters)
      const counters = document.querySelectorAll('.bs-signal__number');
      ScrollTrigger.create({
        trigger: "#BSCommunity",
        start: "top 80%",
        once: true,
        onEnter: () => {
          counters.forEach(counter => {
            const target = +counter.getAttribute('data-target');
            gsap.to(counter, {
              innerHTML: target,
              duration: 2,
              snap: { innerHTML: 1 },
              ease: "power2.out"
            });
          });
        }
      });

      // 9. Quote Wall Parallax
      gsap.to("#Quote1", { x: "-20%", scrollTrigger: { trigger: "#BSQuoteWall", scrub: 1 } });
      gsap.to("#Quote2", { x: "20%", scrollTrigger: { trigger: "#BSQuoteWall", scrub: 1.5 } });
      gsap.to("#Quote3", { x: "-10%", scrollTrigger: { trigger: "#BSQuoteWall", scrub: 2 } });
    }
  }

  // 6. Three.js Future Horizon (Lightweight Points)
  const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(!isReducedMotion) {
    let hasInitialized = false;
    const observer = new IntersectionObserver((entries) => {
      if(entries[0].isIntersecting && !hasInitialized) {
        hasInitialized = true;
        const checkThree = setInterval(() => {
          if(window.THREE) {
            clearInterval(checkThree);
            initHorizon();
          }
        }, 100);
      }
    });
    const container = document.querySelector('.bs-future__pin') || document.getElementById('FutureCanvas');
    if (container) observer.observe(container);
  }

  function initHorizon() {
    const container = document.querySelector('.bs-future__pin') || document.getElementById('BSFuture');
    const canvas = document.createElement('canvas');
    canvas.id = 'FutureCanvas';
    container.insertBefore(canvas, container.firstChild);
    
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, container.clientWidth / container.clientHeight, 1, 1000);
    camera.position.z = 50;
    camera.position.y = 10;

    const renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: false });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Particle Grid
    const geometry = new THREE.BufferGeometry();
    const particles = 2000;
    const positions = new Float32Array(particles * 3);
    
    let i = 0;
    for(let ix = 0; ix < 50; ix++) {
      for(let iz = 0; iz < 40; iz++) {
        positions[i] = ix * 4 - 100; // x
        positions[i+1] = 0;          // y
        positions[i+2] = iz * 4 - 80; // z
        i += 3;
      }
    }
    
    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    
    const isLight = document.documentElement.getAttribute('data-theme') === 'light';
    const material = new THREE.PointsMaterial({
      color: isLight ? 0x00D9FF : 0x7FD9FF,
      size: 0.5,
      transparent: true,
      opacity: 0.8
    });

    const particlesMesh = new THREE.Points(geometry, material);
    scene.add(particlesMesh);

    // Theme Observer for Horizon
    const observer = new MutationObserver(() => {
      const light = document.documentElement.getAttribute('data-theme') === 'light';
      material.color.setHex(light ? 0x00D9FF : 0x7FD9FF);
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    let count = 0;
    
    // Intersection Observer to pause Three.js when offscreen
    let isVisible = false;
    const io = new IntersectionObserver(entries => {
      isVisible = entries[0].isIntersecting;
    });
    io.observe(document.getElementById('BSFuture'));

    function animate() {
      requestAnimationFrame(animate);
      if(!isVisible || document.hidden) return;

      count += 0.02;
      const positions = geometry.attributes.position.array;

      let i = 0;
      
      // Precalculate sine values (reduces 4000 Math.sin operations to 90 per frame)
      const sinX = new Float32Array(50);
      for(let ix = 0; ix < 50; ix++) {
        sinX[ix] = Math.sin((ix + count) * 0.3) * 5;
      }
      
      const sinZ = new Float32Array(40);
      for(let iz = 0; iz < 40; iz++) {
        sinZ[iz] = Math.sin((iz + count) * 0.5) * 5;
      }

      for(let ix = 0; ix < 50; ix++) {
        const sx = sinX[ix];
        for(let iz = 0; iz < 40; iz++) {
          positions[i+1] = sx + sinZ[iz];
          i += 3;
        }
      }
      geometry.attributes.position.needsUpdate = true;
      
      // Slow forward movement
      particlesMesh.position.z += 0.1;
      if(particlesMesh.position.z > 10) particlesMesh.position.z = 0;

      renderer.render(scene, camera);
    }
    animate();

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      }, 250);
    });
  }
});
</script>

