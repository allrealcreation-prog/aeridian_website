<style>
  .wishlist-hero {
    text-align: center;
    padding: var(--space-120) var(--space-24) var(--space-64);
    background: var(--bg-primary);
  }
  .wishlist-hero__icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--space-32);
    color: var(--text-primary);
    animation: floating 6s ease-in-out infinite;
  }
  @keyframes floating {
    0% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0); }
  }
  .wishlist-hero__title {
    font-size: var(--font-heading-1);
    margin-bottom: var(--space-16);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .wishlist-hero__subtitle {
    font-size: var(--font-body-large);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .wishlist-grid-container {
    padding: 0 var(--space-24) var(--space-120);
    max-width: var(--container-large);
    margin: 0 auto;
  }

  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-48) var(--space-32);
  }
  
  @media screen and (max-width: 1024px) {
    .wishlist-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media screen and (max-width: 767px) {
    .wishlist-grid {
      grid-template-columns: 1fr;
      gap: var(--space-32);
    }
  }

  /* Empty State Specifics */
  .wishlist-empty {
    display: none;
    text-align: center;
    padding: var(--space-64) 0;
  }
  .wishlist-empty.is-active {
    display: block;
  }
  .wishlist-empty p {
    color: var(--text-secondary);
    margin-bottom: var(--space-32);
    font-size: var(--font-body-large);
  }

  /* Product Card Placeholders */
  .wishlist-card {
    position: relative;
    display: flex;
    flex-direction: column;
    group: hover;
  }
  .wishlist-card__image-wrapper {
    position: relative;
    aspect-ratio: 4/5;
    background: var(--bg-secondary);
    overflow: hidden;
    margin-bottom: var(--space-16);
    border-radius: var(--radius-sm);
  }
  .wishlist-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-premium);
  }
  .wishlist-card:hover .wishlist-card__image {
    transform: scale(1.05);
  }
  .wishlist-card__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .wishlist-card__title {
    font-size: var(--font-body-large);
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
  }
  .wishlist-card__price {
    font-size: var(--font-body-small);
    color: var(--text-secondary);
  }
  .wishlist-card__remove {
    position: absolute;
    top: var(--space-16);
    right: var(--space-16);
    background: var(--glass-bg);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--duration-fast), color var(--duration-fast);
    z-index: 10;
  }
  .wishlist-card__remove:hover {
    background: var(--text-primary);
    color: var(--bg-primary);
  }
</style>

<div class="wishlist-hero">
  <svg class="wishlist-hero__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <h1 class="wishlist-hero__title">{{ section.settings.heading | default: 'Saved Artifacts' }}</h1>
  <p class="wishlist-hero__subtitle">{{ section.settings.subtitle | default: 'Your curated selection of AERIDIAN equipment. These items are saved locally to your device.' }}</p>
</div>

<div class="wishlist-grid-container">
  
  <div class="wishlist-empty" id="WishlistEmptyState">
    <p>{{ section.settings.empty_text | default: 'Your archive is currently empty. Discover new technical layers and equipment.' }}</p>
    <a href="{{ section.settings.empty_url | default: routes.all_products_collection_url }}" class="btn-primary" style="display: inline-block;">{{ section.settings.empty_btn_text | default: 'Explore Collection' }}</a>
  </div>

  <div class="wishlist-grid" id="WishlistGridRender">
    <!-- Populated by JS -->
  </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const storageKey = 'aeridian_wishlist';
  const items = JSON.parse(localStorage.getItem(storageKey)) || [];
  const grid = document.getElementById('WishlistGridRender');
  const emptyState = document.getElementById('WishlistEmptyState');

  if (items.length === 0) {
    emptyState.classList.add('is-active');
  } else {
    // Generate Placeholder Cards for Saved Handles
    items.forEach(handle => {
      const card = document.createElement('div');
      card.className = 'wishlist-card';
      
      // In a real environment, we would fetch product data via /products/handle.js
      // For this luxury fallback, we generate a premium placeholder structure
      const removeBtn = document.createElement('button');
      removeBtn.className = 'wishlist-card__remove';
      removeBtn.setAttribute('aria-label', 'Remove from wishlist');
      removeBtn.addEventListener('click', function() {
        removeFromWishlist(handle, this);
      });

      const svgNs = "http://www.w3.org/2000/svg";
      const svgCross = document.createElementNS(svgNs, 'svg');
      svgCross.setAttribute('width', '14');
      svgCross.setAttribute('height', '14');
      svgCross.setAttribute('viewBox', '0 0 24 24');
      svgCross.setAttribute('fill', 'none');
      svgCross.setAttribute('stroke', 'currentColor');
      svgCross.setAttribute('stroke-width', '2');

      const pathCross = document.createElementNS(svgNs, 'path');
      pathCross.setAttribute('d', 'M18 6L6 18M6 6l12 12');
      svgCross.appendChild(pathCross);
      removeBtn.appendChild(svgCross);
      card.appendChild(removeBtn);

      const imageWrapper = document.createElement('a');
      imageWrapper.href = '/products/' + encodeURIComponent(handle);
      imageWrapper.className = 'wishlist-card__image-wrapper';

      const imageInner = document.createElement('div');
      imageInner.style.width = '100%';
      imageInner.style.height = '100%';
      imageInner.style.display = 'flex';
      imageInner.style.alignItems = 'center';
      imageInner.style.justifyContent = 'center';
      imageInner.style.color = 'var(--text-secondary)';
      imageInner.style.opacity = '0.5';

      const svgPlaceholder = document.createElementNS(svgNs, 'svg');
      svgPlaceholder.setAttribute('width', '48');
      svgPlaceholder.setAttribute('height', '48');
      svgPlaceholder.setAttribute('viewBox', '0 0 24 24');
      svgPlaceholder.setAttribute('fill', 'none');
      svgPlaceholder.setAttribute('stroke', 'currentColor');
      svgPlaceholder.setAttribute('stroke-width', '1');

      const rect = document.createElementNS(svgNs, 'rect');
      rect.setAttribute('x', '3');
      rect.setAttribute('y', '3');
      rect.setAttribute('width', '18');
      rect.setAttribute('height', '18');
      rect.setAttribute('rx', '2');
      rect.setAttribute('ry', '2');

      const circle = document.createElementNS(svgNs, 'circle');
      circle.setAttribute('cx', '8.5');
      circle.setAttribute('cy', '8.5');
      circle.setAttribute('r', '1.5');

      const polyline = document.createElementNS(svgNs, 'polyline');
      polyline.setAttribute('points', '21 15 16 10 5 21');

      svgPlaceholder.appendChild(rect);
      svgPlaceholder.appendChild(circle);
      svgPlaceholder.appendChild(polyline);
      imageInner.appendChild(svgPlaceholder);
      imageWrapper.appendChild(imageInner);
      card.appendChild(imageWrapper);

      const infoContainer = document.createElement('div');
      infoContainer.className = 'wishlist-card__info';

      const titleLink = document.createElement('a');
      titleLink.href = '/products/' + encodeURIComponent(handle);
      titleLink.className = 'wishlist-card__title';
      titleLink.style.textTransform = 'capitalize';
      titleLink.textContent = handle.replace(/-/g, ' ');
      infoContainer.appendChild(titleLink);

      const priceDiv = document.createElement('div');
      priceDiv.className = 'wishlist-card__price';
      priceDiv.textContent = 'AERIDIAN Artifact';
      infoContainer.appendChild(priceDiv);

      const viewDetailsBtn = document.createElement('a');
      viewDetailsBtn.href = '/products/' + encodeURIComponent(handle);
      viewDetailsBtn.className = 'btn-secondary';
      viewDetailsBtn.style.marginTop = '8px';
      viewDetailsBtn.style.textAlign = 'center';
      viewDetailsBtn.style.width = '100%';
      viewDetailsBtn.textContent = 'View Details';
      infoContainer.appendChild(viewDetailsBtn);

      card.appendChild(infoContainer);

      grid.appendChild(card);
    });
  }
});

function removeFromWishlist(handle, btnElement) {
  const storageKey = 'aeridian_wishlist';
  let items = JSON.parse(localStorage.getItem(storageKey)) || [];
  
  items = items.filter(i => i !== handle);
  localStorage.setItem(storageKey, JSON.stringify(items));
  
  // Remove the card from DOM
  const card = btnElement.closest('.wishlist-card');
  if (card) {
    card.style.opacity = '0';
    card.style.transform = 'scale(0.95)';
    card.style.transition = 'all 0.3s ease';
    setTimeout(() => {
      card.remove();
      // Check if empty
      if (items.length === 0) {
        document.getElementById('WishlistEmptyState').classList.add('is-active');
      }
    }, 300);
  }
  
  // Update header icons if needed
  window.dispatchEvent(new CustomEvent('aeridian:wishlist-updated'));
}
</script>

{% schema %}
{
  "name": "Wishlist Matrix",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Saved Artifacts"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Your curated selection of AERIDIAN equipment. These items are saved locally to your device."
    },
    {
      "type": "header",
      "content": "Empty State"
    },
    {
      "type": "textarea",
      "id": "empty_text",
      "label": "Empty State Text",
      "default": "Your archive is currently empty. Discover new technical layers and equipment."
    },
    {
      "type": "text",
      "id": "empty_btn_text",
      "label": "Button Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "empty_url",
      "label": "Button Link"
    }
  ]
}
{% endschema %}
