<style>
  .wishlist-hero {
    text-align: center;
    padding: var(--space-120) var(--space-24) var(--space-64);
    background: var(--bg-primary);
  }
  .wishlist-hero__icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--space-32);
    color: var(--text-primary);
    animation: floating 6s ease-in-out infinite;
  }
  @keyframes floating {
    0% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0); }
  }
  .wishlist-hero__title {
    font-size: var(--font-heading-1);
    margin-bottom: var(--space-16);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .wishlist-hero__subtitle {
    font-size: var(--font-body-large);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .wishlist-grid-container {
    padding: 0 var(--space-24) var(--space-120);
    max-width: var(--container-large);
    margin: 0 auto;
  }

  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-48) var(--space-32);
  }
  
  @media screen and (max-width: 1024px) {
    .wishlist-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media screen and (max-width: 767px) {
    .wishlist-grid {
      grid-template-columns: 1fr;
      gap: var(--space-32);
    }
  }

  /* Empty State Specifics */
  .wishlist-empty {
    display: none;
    text-align: center;
    padding: var(--space-64) 0;
  }
  .wishlist-empty.is-active {
    display: block;
  }
  .wishlist-empty p {
    color: var(--text-secondary);
    margin-bottom: var(--space-32);
    font-size: var(--font-body-large);
  }

  /* Product Card Placeholders */
  .wishlist-card {
    position: relative;
    display: flex;
    flex-direction: column;
    group: hover;
  }
  .wishlist-card__image-wrapper {
    position: relative;
    aspect-ratio: 4/5;
    background: var(--bg-secondary);
    overflow: hidden;
    margin-bottom: var(--space-16);
    border-radius: var(--radius-sm);
  }
  .wishlist-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-premium);
  }
  .wishlist-card:hover .wishlist-card__image {
    transform: scale(1.05);
  }
  .wishlist-card__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .wishlist-card__title {
    font-size: var(--font-body-large);
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
  }
  .wishlist-card__price {
    font-size: var(--font-body-small);
    color: var(--text-secondary);
  }
  .wishlist-card__remove {
    position: absolute;
    top: var(--space-16);
    right: var(--space-16);
    background: var(--glass-bg);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--duration-fast), color var(--duration-fast);
    z-index: 10;
  }
  .wishlist-card__remove:hover {
    background: var(--text-primary);
    color: var(--bg-primary);
  }
  
  /* Skeleton Animations */
  @keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.5; }
    100% { opacity: 1; }
  }
  .skeleton-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>

<div class="wishlist-hero">
  <svg class="wishlist-hero__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <h1 style="font-size: var(--font-display-l); font-family: var(--font-heading); font-weight: 300; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: var(--space-16);">{{ section.settings.heading | default: 'Saved Artifacts' }}</h1>
  <p style="font-size: var(--font-body-large); color: var(--text-secondary); max-width: 600px; margin: 0 auto; line-height: 1.6;">{{ section.settings.subtitle | default: 'Your curated selection of AERIDIAN equipment. These items are saved locally to your device.' }}</p>
</div>

<div class="wishlist-grid-container">
  
  <div class="wishlist-empty" id="WishlistEmptyState">
    <div style="max-width: 400px; margin: 0 auto;">
      <p style="font-size: var(--font-body-large); color: var(--text-secondary); margin-bottom: var(--space-32);">{{ section.settings.empty_text | default: 'Your archive is currently empty. Discover new technical layers and equipment.' }}</p>
      <a href="{{ section.settings.empty_url | default: routes.all_products_collection_url }}" class="btn-primary js-magnetic" data-magnetic-intensity="0.2" style="display: inline-block;">{{ section.settings.empty_btn_text | default: 'Explore Collection' }}</a>
    </div>
  </div>

  <template id="WishlistSkeletonTemplate">
    <div class="wishlist-card wishlist-card--skeleton">
      <div class="wishlist-card__image-wrapper skeleton-pulse" style="background: var(--bg-secondary);"></div>
      <div class="wishlist-card__info" style="gap: var(--space-8);">
        <div class="skeleton-pulse" style="height: 1.5rem; width: 80%; background: var(--bg-secondary); border-radius: var(--radius-sm);"></div>
        <div class="skeleton-pulse" style="height: 1rem; width: 40%; background: var(--bg-secondary); border-radius: var(--radius-sm);"></div>
      </div>
    </div>
  </template>

  <div class="wishlist-grid" id="WishlistGridRender">
    <!-- Populated by JS -->
  </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const storageKey = 'aeridian_wishlist';
  const items = JSON.parse(localStorage.getItem(storageKey)) || [];
  const grid = document.getElementById('WishlistGridRender');
  const emptyState = document.getElementById('WishlistEmptyState');

  if (items.length === 0) {
    emptyState.classList.add('is-active');
  } else {
    // Generate Skeleton Cards for Saved Handles
    items.forEach(handle => {
      const template = document.getElementById('WishlistSkeletonTemplate');
      const skeletonFragment = template.content.cloneNode(true);
      const skeleton = skeletonFragment.querySelector('.wishlist-card--skeleton');
      skeleton.dataset.handle = handle;
      
      grid.appendChild(skeleton);
      
      // Fetch the actual card via Section Rendering API
      fetch(`/products/${handle}?section_id=wishlist-card-renderer`)
        .then(res => res.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const renderedCard = doc.querySelector('.wishlist-card-wrapper');
          if (renderedCard) {
            renderedCard.className = 'wishlist-card'; // Add grid classes
            grid.replaceChild(renderedCard, skeleton);
          } else {
            // Product not found or error, remove skeleton
            skeleton.remove();
          }
        })
        .catch(err => {
          console.error('Failed to load wishlist card for:', handle, err);
          skeleton.remove();
        });
    });
  }
});

function removeFromWishlist(handle, btnElement) {
  const storageKey = 'aeridian_wishlist';
  let items = JSON.parse(localStorage.getItem(storageKey)) || [];
  
  items = items.filter(i => i !== handle);
  localStorage.setItem(storageKey, JSON.stringify(items));
  
  // Remove the card from DOM
  const card = btnElement.closest('.wishlist-card');
  if (card) {
    card.style.opacity = '0';
    card.style.transform = 'scale(0.95)';
    card.style.transition = 'all 0.3s ease';
    setTimeout(() => {
      card.remove();
      // Check if empty
      if (items.length === 0) {
        document.getElementById('WishlistEmptyState').classList.add('is-active');
      }
    }, 300);
  }
  
  const counter = document.getElementById('WishlistCount');
  if (counter) counter.innerText = items.length;
  
  // Update header icons if needed
  window.dispatchEvent(new CustomEvent('aeridian:wishlist-updated'));
}
</script>

{% schema %}
{
  "name": "Wishlist Matrix",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Saved Artifacts"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Your curated selection of AERIDIAN equipment. These items are saved locally to your device."
    },
    {
      "type": "header",
      "content": "Empty State"
    },
    {
      "type": "textarea",
      "id": "empty_text",
      "label": "Empty State Text",
      "default": "Your archive is currently empty. Discover new technical layers and equipment."
    },
    {
      "type": "text",
      "id": "empty_btn_text",
      "label": "Button Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "empty_url",
      "label": "Button Link"
    }
  ]
}
{% endschema %}
