<div class="container container--narrow" style="padding-top: var(--space-120); padding-bottom: var(--space-120);">
  <h1 class="page-title" style="text-align: center; margin-bottom: var(--space-48);">{{ page.title }}</h1>
  <div class="page-content" style="color: var(--text-secondary); line-height: 1.6;">
    {%- if page.content != blank -%}
      {{ page.content }}
    {%- else -%}
      <p style="text-align: center;">Content for {{ page.title }} will appear here.</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
