<style>
  .hero-cinematic {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: #111111;
    overflow: hidden;
    color: var(--text-primary);
    display: flex;
    align-items: center;
  }

  html[data-theme='light'] .hero-cinematic {
    background-color: #fafaf9;
  }

  /* Pure CSS Background Grid */
  .hero-cinematic__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    background-position: center center;
    transform: perspective(500px) rotateX(60deg) scale(2);
    transform-origin: bottom center;
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
    transition: opacity var(--duration-slow);
  }

  /* Light Mode Override for Grid */
  html[data-theme="light"] .hero-cinematic__bg {
    background-image: 
      linear-gradient(rgba(0, 0, 0, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
  }

  .hero-cinematic__container {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: var(--container-large);
    margin: 0 auto;
    padding: 0 var(--space-24);
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  /* LEFT: Content Block */
  .hero-content {
    width: 50%;
    padding-right: var(--space-48);
    display: flex;
    flex-direction: column;
    justify-content: center;
    transform: translateY(-15px);
  }

  .hero-eyebrow {
    font-size: var(--font-caption);
    letter-spacing: var(--tracking-caption);
    color: var(--text-secondary);
    text-transform: uppercase;
    margin-bottom: var(--space-24);
  }

  .hero-logo {
    max-width: 100%;
    height: auto;
  }

  .hero-tagline-animate {
    /* Storytelling Reveal Managed */
  }

  .hero-buttons {
    display: flex;
    gap: var(--space-16);
  }



  /* RIGHT: WebGL Canvas Container */
  .hero-canvas-wrapper {
    width: 50%;
    height: 80%;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #AeridianCoreCanvas {
    width: 100%;
    height: 100%;
    outline: none;
    opacity: 0;
    transition: opacity var(--duration-reveal) var(--ease-luxury);
  }

  #AeridianCoreCanvas.is-ready {
    opacity: 1;
  }

  /* Mobile Layout */
  @media screen and (max-width: 1024px) {
    .hero-cinematic__container {
      flex-direction: column;
      justify-content: center;
      padding-top: 80px; /* Account for header */
    }
    
    .hero-content {
      width: 100%;
      text-align: center;
      padding-right: 0;
      order: 1;
      align-items: center;
    }

    .hero-canvas-wrapper {
      width: 100%;
      height: 45vh;
      order: 2;
      margin: var(--space-24) 0;
    }

    .hero-eyebrow { order: 1; }
    .hero-logo-wrapper { order: 2; }
    .hero-tagline { order: 4; margin-bottom: var(--space-24); font-size: var(--font-heading-3); }
    .hero-buttons { order: 5; flex-direction: column; width: 100%; }
    .btn-magnetic-wrapper { width: 100%; }
    .btn-primary, .btn-secondary { width: 100%; }
  }

  /* Reduced Motion Fallback */
  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-logo, .hero-tagline, .hero-buttons {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
    #AeridianCoreCanvas { display: none; }
  }

  /* Atmospheric Center Glow */
  .hero-cinematic::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.04) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  html[data-theme='light'] .hero-cinematic::before {
    background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.6) 0%, transparent 70%);
  }
</style>

<section class="hero-cinematic" data-section-id="{{ section.id }}" data-reveal-sequence="true">
  <div class="hero-cinematic__bg" id="HeroGrid" data-reveal-role="background" data-reveal-effect="opacity"></div>
  
  <div class="hero-cinematic__container" id="HeroContainer">
    <!-- LEFT CONTENT -->
    <div class="hero-content">
      <div class="hero-eyebrow" data-reveal-role="eyebrow">{{ section.settings.eyebrow }}</div>
      
      <div class="brand-lockup" style="margin-bottom: var(--space-48);">
        <div class="brand-lockup__wordmark" style="overflow: hidden;" data-reveal-role="headline" data-reveal-effect="mask">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 800 }}" alt="{{ shop.name }}" class="hero-logo" width="{{ section.settings.logo.width }}" height="{{ section.settings.logo.height }}" fetchpriority="high" loading="eager">
          {%- else -%}
            <h1 class="hero-logo" style="margin: 0; line-height: 0; display: block; max-width: 400px; width: 100%;">
              {% render 'icon-wordmark' %}
            </h1>
          {%- endif -%}
        </div>

        <div class="brand-lockup__tagline hero-tagline-animate" style="color: var(--color-primary-soft-white);" data-reveal-role="body" data-reveal-level="C">{{ section.settings.tagline }}</div>
      </div>

      <div class="hero-buttons" data-reveal-role="cta">
        {%- if section.settings.primary_link != blank -%}
          <div class="btn-magnetic-wrapper js-magnetic" data-magnetic-intensity="0.4">
            <a href="{{ section.settings.primary_link }}" class="btn-primary">{{ section.settings.primary_label }}</a>
          </div>
        {%- endif -%}
        {%- if section.settings.secondary_link != blank -%}
          <div class="btn-magnetic-wrapper js-magnetic" data-magnetic-intensity="0.2">
            <a href="{{ section.settings.secondary_link }}" class="btn-secondary">{{ section.settings.secondary_label }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- RIGHT THREE.JS CANVAS -->
    <div class="hero-canvas-wrapper" id="CanvasWrapper">
      <canvas id="AeridianCoreCanvas"></canvas>
    </div>
  </div>
</section>

<!-- Defer Three.js Library -->
<script src="{{ 'three.min.js' | asset_url }}" defer></script>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(isReducedMotion) return; // Do not initialize Three.js if reduced motion is preferred

  // 1. Magnetic Buttons Logic
  const magneticWrappers = document.querySelectorAll('.btn-magnetic-wrapper');
  magneticWrappers.forEach(wrapper => {
    const btn = wrapper.firstElementChild;
    
    wrapper.addEventListener('mousemove', (e) => {
      const rect = wrapper.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      
      // Limit pull to 15px max
      const maxPull = 15;
      const pullX = Math.max(-maxPull, Math.min(maxPull, x * 0.3));
      const pullY = Math.max(-maxPull, Math.min(maxPull, y * 0.3));
      
      btn.style.transform = `translate(${pullX}px, ${pullY}px)`;
    });

    wrapper.addEventListener('mouseleave', () => {
      btn.style.transform = `translate(0px, 0px)`;
    });
  });

  // 2. Scroll Parallax Logic
  const heroSection = document.querySelector('.hero-cinematic');
  const heroContent = document.querySelector('.hero-content');
  const heroCanvasWrapper = document.querySelector('.hero-canvas-wrapper');

  if (window.gsap && window.ScrollTrigger) {
    gsap.to(heroContent, {
      yPercent: 30,
      ease: 'none',
      scrollTrigger: {
        trigger: heroSection,
        start: 'top top',
        end: 'bottom top',
        scrub: true
      }
    });
  }

  // Register with Storytelling Engine
  if (window.AERIDIAN && window.AERIDIAN.Utils.Storytelling) {
    window.AERIDIAN.Utils.Storytelling.register({
      selector: '.hero-cinematic',
      timeline: 'hero'
    });
  }

  const heroCanvas = document.getElementById('CanvasWrapper');
  const heroGrid = document.getElementById('HeroGrid');

  window.addEventListener('scroll', () => {
    if(!heroSection) return;
    const scrollY = window.scrollY;
    
    // Only calculate if within first screen
    if(scrollY < window.innerHeight) {
      // Fade content
      heroContent.style.opacity = Math.max(0, 1 - (scrollY / 400));
      heroContent.style.transform = `translateY(${scrollY * 0.2}px)`;
      
      // Move Core up
      heroCanvas.style.transform = `translateY(${scrollY * -0.3}px)`;
      
      // Fade grid
      heroGrid.style.opacity = Math.max(0, 0.4 - (scrollY / 1000));
    }
  }, { passive: true });

  // 3. Three.js Initialization (Wait for script to load)
  const checkThreeInterval = setInterval(() => {
    if(window.THREE) {
      clearInterval(checkThreeInterval);
      initThreeJs();
    }
  }, 100);

  let isRendering = false;

  function initThreeJs() {
    if (isRendering) return;
    isRendering = true;

    const canvas = document.getElementById('AeridianCoreCanvas');
    const wrapper = document.getElementById('CanvasWrapper');
    
    // Scene setup
    const scene = new THREE.Scene();
    
    // Camera setup
    const camera = new THREE.PerspectiveCamera(45, wrapper.clientWidth / wrapper.clientHeight, 0.1, 1000);
    camera.position.z = 10;

    // Renderer setup
    const renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
    renderer.setSize(wrapper.clientWidth, wrapper.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // Limit pixel ratio for performance

    // --- GEOMETRIES ---
    const initIsLight = document.documentElement.getAttribute('data-theme') === 'light';
    const initColor = initIsLight ? 0x444444 : 0xe8e8e8;

    // Premium Abstract Sculpture (Torus Knot)
    const shellGeo = new THREE.TorusKnotGeometry(1.8, 0.5, 256, 64, 3, 5);
    const shellMat = new THREE.MeshPhysicalMaterial({
      color: initColor,
      emissive: 0x000000,
      metalness: 0.6,
      roughness: 0.3,
      clearcoat: 1.0,
      clearcoatRoughness: 0.1,
      transmission: 0.0, // luxury glass/resin effect removed for ceramic
      ior: 1.5
    });
    const shell = new THREE.Mesh(shellGeo, shellMat);
    scene.add(shell);

    // --- LIGHTING ---
    // Energy Light (Cyan Internal Glow)
    const coreLight = new THREE.PointLight(0x7FD9FF, 2, 20);
    scene.add(coreLight);
    
    // Key Light (White)
    const keyLight = new THREE.DirectionalLight(0xffffff, 2.5);
    keyLight.position.set(5, 5, 5);
    scene.add(keyLight);

    // Fill Light (Subtle blue)
    const fillLight = new THREE.DirectionalLight(0xaaccff, 0.8);
    fillLight.position.set(-5, -2, 5);
    scene.add(fillLight);

    // Rim Light (White)
    const rimLight = new THREE.DirectionalLight(0xffffff, 2.0);
    rimLight.position.set(0, 5, -10);
    scene.add(rimLight);

    // Ambient Light
    const initAmbient = initIsLight ? 1.2 : 0.4;
    const ambientLight = new THREE.AmbientLight(0xffffff, initAmbient);
    scene.add(ambientLight);

    // Ambient Particles
    const particlesGeo = new THREE.BufferGeometry();
    const particleCount = 150;
    const posArray = new Float32Array(particleCount * 3);
    for(let i = 0; i < particleCount * 3; i++) {
      posArray[i] = (Math.random() - 0.5) * 15;
    }
    particlesGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
    const particlesMat = new THREE.PointsMaterial({
      size: 0.05,
      color: 0x7FD9FF,
      transparent: true,
      opacity: 0.4,
      blending: THREE.AdditiveBlending
    });
    const particleSystem = new THREE.Points(particlesGeo, particlesMat);
    scene.add(particleSystem);

    // Fade in canvas
    canvas.classList.add('is-ready');

    // --- INTERACTION LOGIC ---
    let mouseX = 0;
    let mouseY = 0;
    let targetX = 0;
    let targetY = 0;
    const windowHalfX = window.innerWidth / 2;
    const windowHalfY = window.innerHeight / 2;

    document.addEventListener('mousemove', (event) => {
      mouseX = (event.clientX - windowHalfX);
      mouseY = (event.clientY - windowHalfY);
    });

    // Handle Resize
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        camera.aspect = wrapper.clientWidth / wrapper.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(wrapper.clientWidth, wrapper.clientHeight);
      }, 250);
    });

    // Theme Listener for Hero
    window.addEventListener('AeridianThemeChange', (e) => {
      const isLight = e.detail.theme === 'light';
      const targetColor = isLight ? new THREE.Color(0x444444) : new THREE.Color(0xe8e8e8);
      const targetAmbient = isLight ? 1.2 : 0.4;
      
      if(typeof gsap !== 'undefined') {
        gsap.to(shellMat.color, { r: targetColor.r, g: targetColor.g, b: targetColor.b, duration: 0.5, ease: "power2.inOut" });
        gsap.to(ambientLight, { intensity: targetAmbient, duration: 0.5, ease: "power2.inOut" });
      } else {
        shellMat.color.copy(targetColor);
        ambientLight.intensity = targetAmbient;
      }
    });

    // --- ANIMATION LOOP ---
    const clock = new THREE.Clock();
    let isHovered = false;
    let baseRotationY = 0;

    // Raycaster for hover
    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();

    wrapper.addEventListener('mousemove', (e) => {
      const rect = wrapper.getBoundingClientRect();
      mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
      
      raycaster.setFromCamera(mouse, camera);
      const intersects = raycaster.intersectObject(shell);
      isHovered = intersects.length > 0;
    });

    const renderFrame = () => {
      if(!isRendering || document.hidden) return;

      const deltaTime = clock.getDelta();
      const elapsedTime = clock.getElapsedTime();

      // Continuous Rotation
      const rotationSpeed = (Math.PI * 2) / 150; // 150s per rev
      baseRotationY += deltaTime * rotationSpeed;
      
      // Floating Sine Wave
      shell.position.y = Math.sin(elapsedTime * 0.5) * 0.3;
      coreLight.position.y = shell.position.y;

      // Particle Drift
      particleSystem.rotation.y = elapsedTime * 0.02;

      // Hover Energy Pulse
      if(isHovered) {
        coreLight.intensity = THREE.MathUtils.lerp(coreLight.intensity, 4 + Math.sin(elapsedTime * 5), 0.1);
        baseRotationY += 0.005; // Spin slightly faster
      } else {
        coreLight.intensity = THREE.MathUtils.lerp(coreLight.intensity, 2 + Math.sin(elapsedTime * 2) * 0.5, 0.05);
      }

      // Mouse Look Constraint (Max 10 degrees)
      targetX = mouseX * 0.001;
      targetY = mouseY * 0.001;
      
      const maxRotation = THREE.MathUtils.degToRad(10);
      targetX = Math.max(-maxRotation, Math.min(maxRotation, targetX));
      targetY = Math.max(-maxRotation, Math.min(maxRotation, targetY));

      shell.rotation.y = baseRotationY + (targetX * 0.5); // Apply base rotation + mouse look offset
      shell.rotation.x = Math.sin(elapsedTime * 0.1) * 0.005 + (targetY * 0.5); // Subtle X oscillation + mouse look

      renderer.render(scene, camera);
    };

    if (window.AERIDIAN && window.AERIDIAN.RAF) {
      window.AERIDIAN.RAF.add('HeroCinematic', renderFrame);
    } else {
      function animate() {
        requestAnimationFrame(animate);
        renderFrame();
      }
      animate();
    }
  }
});
</script>

{% schema %}
{
  "name": "Cinematic Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "ALWAYS NEW TO THE WORLD"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Main Title/Logo Image",
      "info": "Upload the transparent AERIDIAN wordmark SVG here."
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline / Description",
      "default": "Redefining streetwear through innovation.<br>Designed for those who move differently.<br>Built for tomorrow."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary Button Label",
      "default": "EXPLORE COLLECTIONS"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Cinematic Hero"
    }
  ]
}
{% endschema %}
