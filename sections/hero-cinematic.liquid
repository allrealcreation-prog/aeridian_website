<style>
  .hero-cinematic {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    display: flex;
    align-items: center;
  }

  /* Pure CSS Background Grid */
  .hero-cinematic__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    background-position: center center;
    transform: perspective(500px) rotateX(60deg) scale(2);
    transform-origin: bottom center;
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
    transition: opacity var(--duration-slow);
  }

  /* Light Mode Override for Grid */
  html[data-theme="light"] .hero-cinematic__bg {
    background-image: 
      linear-gradient(rgba(0, 0, 0, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
  }

  .hero-cinematic__container {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: var(--container-large);
    margin: 0 auto;
    padding: 0 var(--space-24);
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  /* LEFT: Content Block */
  .hero-content {
    width: 50%;
    padding-right: var(--space-48);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-eyebrow {
    font-size: var(--font-caption);
    letter-spacing: var(--tracking-caption);
    color: var(--text-secondary);
    text-transform: uppercase;
    margin-bottom: var(--space-24);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp var(--duration-slow) var(--ease-luxury) 0.5s forwards;
  }

  .hero-logo {
    max-width: 100%;
    height: auto;
    transform: translateY(100%);
    opacity: 0;
    animation: revealUp var(--duration-slow) var(--ease-luxury) 0.7s forwards;
  }

  .hero-tagline-animate {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp var(--duration-slow) var(--ease-luxury) 0.9s forwards;
  }

  .hero-buttons {
    display: flex;
    gap: var(--space-16);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp var(--duration-slow) var(--ease-luxury) 1.1s forwards;
  }



  /* RIGHT: WebGL Canvas Container */
  .hero-canvas-wrapper {
    width: 50%;
    height: 80%;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #AeridianCoreCanvas {
    width: 100%;
    height: 100%;
    outline: none;
    opacity: 0;
    transition: opacity var(--duration-reveal) var(--ease-luxury);
  }

  #AeridianCoreCanvas.is-ready {
    opacity: 1;
  }

  /* Keyframes */
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes revealUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Mobile Layout */
  @media screen and (max-width: 1024px) {
    .hero-cinematic__container {
      flex-direction: column;
      justify-content: center;
      padding-top: 80px; /* Account for header */
    }
    
    .hero-content {
      width: 100%;
      text-align: center;
      padding-right: 0;
      order: 1;
      align-items: center;
    }

    .hero-canvas-wrapper {
      width: 100%;
      height: 45vh;
      order: 2;
      margin: var(--space-24) 0;
    }

    .hero-eyebrow { order: 1; }
    .hero-logo-wrapper { order: 2; }
    .hero-tagline { order: 4; margin-bottom: var(--space-24); font-size: var(--font-heading-3); }
    .hero-buttons { order: 5; flex-direction: column; width: 100%; }
    .btn-magnetic-wrapper { width: 100%; }
    .btn-primary, .btn-secondary { width: 100%; }
  }

  /* Reduced Motion Fallback */
  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-logo, .hero-tagline, .hero-buttons {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
    .hero-canvas-wrapper {
      background: radial-gradient(circle, var(--color-accent-atmospheric) 0%, transparent 60%);
      opacity: 0.2;
    }
    #AeridianCoreCanvas { display: none; }
  }
</style>

<section class="hero-cinematic" data-section-id="{{ section.id }}">
  <div class="hero-cinematic__bg" id="HeroGrid"></div>
  
  <div class="hero-cinematic__container" id="HeroContainer">
    <!-- LEFT CONTENT -->
    <div class="hero-content">
      <div class="hero-eyebrow">{{ section.settings.eyebrow }}</div>
      
      <div class="brand-lockup" style="margin-bottom: var(--space-48);">
        <div class="brand-lockup__wordmark" style="overflow: hidden;">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 800 }}" alt="{{ shop.name }}" class="hero-logo" width="{{ section.settings.logo.width }}" height="{{ section.settings.logo.height }}" fetchpriority="high" loading="eager">
          {%- else -%}
            <h1 class="hero-logo" style="margin: 0; line-height: 0; display: block; max-width: 400px; width: 100%;">
              {% render 'icon-wordmark' %}
            </h1>
          {%- endif -%}
        </div>

        <div class="brand-lockup__tagline hero-tagline-animate" style="color: var(--color-primary-soft-white);">{{ section.settings.tagline }}</div>
      </div>

      <div class="hero-buttons">
        {%- if section.settings.primary_link != blank -%}
          <div class="btn-magnetic-wrapper js-magnetic" data-magnetic-intensity="0.4">
            <a href="{{ section.settings.primary_link }}" class="btn-primary">{{ section.settings.primary_label }}</a>
          </div>
        {%- endif -%}
        {%- if section.settings.secondary_link != blank -%}
          <div class="btn-magnetic-wrapper js-magnetic" data-magnetic-intensity="0.2">
            <a href="{{ section.settings.secondary_link }}" class="btn-secondary">{{ section.settings.secondary_label }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- RIGHT THREE.JS CANVAS -->
    <div class="hero-canvas-wrapper" id="CanvasWrapper">
      <canvas id="AeridianCoreCanvas"></canvas>
    </div>
  </div>
</section>

<!-- Defer Three.js Library -->
<script src="{{ 'three.min.js' | asset_url }}" defer></script>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(isReducedMotion) return; // Do not initialize Three.js if reduced motion is preferred

  // 1. Magnetic Buttons Logic
  const magneticWrappers = document.querySelectorAll('.btn-magnetic-wrapper');
  magneticWrappers.forEach(wrapper => {
    const btn = wrapper.firstElementChild;
    
    wrapper.addEventListener('mousemove', (e) => {
      const rect = wrapper.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      
      // Limit pull to 15px max
      const maxPull = 15;
      const pullX = Math.max(-maxPull, Math.min(maxPull, x * 0.3));
      const pullY = Math.max(-maxPull, Math.min(maxPull, y * 0.3));
      
      btn.style.transform = `translate(${pullX}px, ${pullY}px)`;
    });

    wrapper.addEventListener('mouseleave', () => {
      btn.style.transform = `translate(0px, 0px)`;
    });
  });

  // 2. Scroll Parallax Logic
  const heroSection = document.querySelector('.hero-cinematic');
  const heroContent = document.querySelector('.hero-content');
  const heroCanvas = document.getElementById('CanvasWrapper');
  const heroGrid = document.getElementById('HeroGrid');

  let cachedInnerHeight = window.innerHeight;
  window.addEventListener('resize', () => {
    cachedInnerHeight = window.innerHeight;
  }, { passive: true });

  let wasPastHero = false;

  const onScroll = () => {
    if(!heroSection) return;
    const scrollY = window.scrollY;
    
    // Only calculate if within first screen
    if(scrollY < cachedInnerHeight) {
      wasPastHero = false;
      // Fade content
      heroContent.style.opacity = Math.max(0, 1 - (scrollY / 400));
      heroContent.style.transform = `translateY(${scrollY * 0.2}px)`;
      
      // Move Core up
      heroCanvas.style.transform = `translateY(${scrollY * -0.3}px)`;
      
      // Fade grid
      heroGrid.style.opacity = Math.max(0, 0.4 - (scrollY / 1000));
    } else if (!wasPastHero) {
      wasPastHero = true;
      heroContent.style.opacity = 0;
      heroContent.style.transform = `translateY(${cachedInnerHeight * 0.2}px)`;
      heroCanvas.style.transform = `translateY(${cachedInnerHeight * -0.3}px)`;
      heroGrid.style.opacity = 0;
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });

  document.addEventListener('shopify:section:unload', function _scrollCleanup(e) {
    if (e.detail.sectionId === '{{ section.id }}') {
      window.removeEventListener('scroll', onScroll);
      document.removeEventListener('shopify:section:unload', _scrollCleanup);
    }
  });

  // 3. Three.js Initialization (Wait for script to load)
  const checkThreeInterval = setInterval(() => {
    if(window.THREE) {
      clearInterval(checkThreeInterval);
      initThreeJs();
    }
  }, 100);

  let isRendering = false;

  function initThreeJs() {
    if (isRendering) return;
    isRendering = true;
    console.log('Hero renderer initialized');

    const canvas = document.getElementById('AeridianCoreCanvas');
    const wrapper = document.getElementById('CanvasWrapper');
    
    // Scene setup
    const scene = new THREE.Scene();
    
    // Camera setup
    const camera = new THREE.PerspectiveCamera(45, wrapper.clientWidth / wrapper.clientHeight, 0.1, 1000);
    camera.position.z = 10;

    // Renderer setup
    const renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
    renderer.setSize(wrapper.clientWidth, wrapper.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // Limit pixel ratio for performance

    // --- GEOMETRIES ---
    // Outer Shell (Glassy Obsidian)
    const shellGeo = new THREE.IcosahedronGeometry(2.5, 1);
    const shellMat = new THREE.MeshPhysicalMaterial({
      color: 0x050505,
      metalness: 0.9,
      roughness: 0.1,
      transmission: 0.9, // glass effect
      clearcoat: 1.0,
      clearcoatRoughness: 0.1
    });
    const shell = new THREE.Mesh(shellGeo, shellMat);
    scene.add(shell);

    // Inner Structure (Wireframe Titanium)
    const innerGeo = new THREE.IcosahedronGeometry(2.2, 2);
    const innerMat = new THREE.MeshStandardMaterial({
      color: 0xBFC3C9,
      metalness: 0.8,
      roughness: 0.2,
      wireframe: true
    });
    const innerCore = new THREE.Mesh(innerGeo, innerMat);
    scene.add(innerCore);

    // Energy Light (Cyan)
    const coreLight = new THREE.PointLight(0x7FD9FF, 2, 20);
    scene.add(coreLight);
    
    // Ambient Light
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
    scene.add(ambientLight);

    // Ambient Particles
    const particlesGeo = new THREE.BufferGeometry();
    const particleCount = 150;
    const posArray = new Float32Array(particleCount * 3);
    for(let i = 0; i < particleCount * 3; i++) {
      posArray[i] = (Math.random() - 0.5) * 15;
    }
    particlesGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
    const particlesMat = new THREE.PointsMaterial({
      size: 0.05,
      color: 0x7FD9FF,
      transparent: true,
      opacity: 0.4,
      blending: THREE.AdditiveBlending
    });
    const particleSystem = new THREE.Points(particlesGeo, particlesMat);
    scene.add(particleSystem);

    // Fade in canvas
    canvas.classList.add('is-ready');

    // --- INTERACTION LOGIC ---
    let mouseX = 0;
    let mouseY = 0;
    let targetX = 0;
    let targetY = 0;
    const windowHalfX = window.innerWidth / 2;
    const windowHalfY = window.innerHeight / 2;

    const onGlobalMouseMove = (event) => {
      mouseX = (event.clientX - windowHalfX);
      mouseY = (event.clientY - windowHalfY);
    };
    document.addEventListener('mousemove', onGlobalMouseMove);

    // Handle Resize
    let resizeTimer;
    const resizeHandler = () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        camera.aspect = wrapper.clientWidth / wrapper.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(wrapper.clientWidth, wrapper.clientHeight);
      }, 250);
    };
    window.addEventListener('resize', resizeHandler);

    // Theme Mode Observer (Update core color based on mode)
    const observer = new MutationObserver(() => {
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';
      if(isLight) {
        shellMat.color.setHex(0x111111); // Slightly lighter for contrast against white
        ambientLight.intensity = 1.0;
      } else {
        shellMat.color.setHex(0x050505);
        ambientLight.intensity = 0.5;
      }
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // --- ANIMATION LOOP ---
    const clock = new THREE.Clock();
    let isHovered = false;

    // Raycaster for hover
    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();
    let wrapperRect = null;

    const onWrapperMouseEnter = () => {
      wrapperRect = wrapper.getBoundingClientRect();
    };

    wrapper.addEventListener('mouseenter', onWrapperMouseEnter);

    const onWrapperResize = () => {
      wrapperRect = null;
    };
    window.addEventListener('resize', onWrapperResize, { passive: true });

    const onWrapperMouseMove = (e) => {
      if (!wrapperRect) wrapperRect = wrapper.getBoundingClientRect();
      mouse.x = ((e.clientX - wrapperRect.left) / wrapperRect.width) * 2 - 1;
      mouse.y = -((e.clientY - wrapperRect.top) / wrapperRect.height) * 2 + 1;
      
      raycaster.setFromCamera(mouse, camera);
      const intersects = raycaster.intersectObject(shell);
      isHovered = intersects.length > 0;
    };
    wrapper.addEventListener('mousemove', onWrapperMouseMove);

    let rafId;
    function animate() {
      if(!isRendering) return;
      rafId = requestAnimationFrame(animate);

      // Pause if tab is inactive
      if(document.hidden) return;

      const elapsedTime = clock.getElapsedTime();

      // Idle Rotation & Floating
      shell.rotation.y += 0.002;
      shell.rotation.x += 0.001;
      innerCore.rotation.y -= 0.003;
      innerCore.rotation.z += 0.002;
      
      // Floating Sine Wave
      shell.position.y = Math.sin(elapsedTime * 0.5) * 0.3;
      innerCore.position.y = shell.position.y;
      coreLight.position.y = shell.position.y;

      // Particle Drift
      particleSystem.rotation.y = elapsedTime * 0.02;

      // Hover Energy Pulse
      if(isHovered) {
        coreLight.intensity = THREE.MathUtils.lerp(coreLight.intensity, 4 + Math.sin(elapsedTime * 5), 0.1);
        shell.rotation.y += 0.005; // Spin slightly faster
      } else {
        coreLight.intensity = THREE.MathUtils.lerp(coreLight.intensity, 2 + Math.sin(elapsedTime * 2) * 0.5, 0.05);
      }

      // Mouse Look Constraint (Max 10 degrees)
      targetX = mouseX * 0.001;
      targetY = mouseY * 0.001;
      
      const maxRotation = THREE.MathUtils.degToRad(10);
      targetX = Math.max(-maxRotation, Math.min(maxRotation, targetX));
      targetY = Math.max(-maxRotation, Math.min(maxRotation, targetY));

      shell.rotation.y += 0.05 * (targetX - shell.rotation.y);
      shell.rotation.x += 0.05 * (targetY - shell.rotation.x);

      renderer.render(scene, camera);
    }

    animate();

    // Section Unload Cleanup
    document.addEventListener('shopify:section:unload', function _cleanup(e) {
      if(e.detail.sectionId === '{{ section.id }}') {
        cancelAnimationFrame(rafId);
        window.removeEventListener('resize', resizeHandler);
        window.removeEventListener('resize', onWrapperResize);
        document.removeEventListener('mousemove', onGlobalMouseMove);
        wrapper.removeEventListener('mousemove', onWrapperMouseMove);
        wrapper.removeEventListener('mouseenter', onWrapperMouseEnter);

        shellGeo.dispose();
        shellMat.dispose();
        coreGeo.dispose();
        coreMat.dispose();
        particlesGeo.dispose();
        particlesMat.dispose();
        renderer.dispose();

        if (renderer.domElement && renderer.domElement.parentNode) {
          renderer.domElement.parentNode.removeChild(renderer.domElement);
        }

        if (typeof observer !== 'undefined') observer.disconnect();
        if (typeof io !== 'undefined') io.disconnect();

        document.removeEventListener('shopify:section:unload', _cleanup);
      }
    });
  }


});
</script>

{% schema %}
{
  "name": "Cinematic Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "ALWAYS NEW TO THE WORLD"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Main Title/Logo Image",
      "info": "Upload the transparent AERIDIAN wordmark SVG here."
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline / Description",
      "default": "Redefining streetwear through innovation.<br>Designed for those who move differently.<br>Built for tomorrow."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary Button Label",
      "default": "EXPLORE COLLECTIONS"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Cinematic Hero"
    }
  ]
}
{% endschema %}
