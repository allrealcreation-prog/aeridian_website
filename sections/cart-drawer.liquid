<!-- AERIDIAN AJAX Cart Drawer -->
<style>
  #CartDrawer {
    position: fixed;
    top: 0; right: 0; width: 100%; max-width: 450px; height: 100vh;
    background: var(--bg-primary);
    border-left: 1px solid var(--border-subtle);
    z-index: 10000;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    display: flex; flex-direction: column;
    box-shadow: -10px 0 30px rgba(0,0,0,0.5);
  }
  #CartDrawer.is-open {
    transform: translateX(0);
  }
  .cart-drawer__overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
    background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
    z-index: 9999; opacity: 0; pointer-events: none;
    transition: opacity 0.5s ease;
  }
  .cart-drawer__overlay.is-active {
    opacity: 1; pointer-events: auto;
  }
  
  .cart-drawer__header {
    padding: var(--space-24);
    border-bottom: 1px solid var(--border-subtle);
    display: flex; justify-content: space-between; align-items: center;
  }
  .cart-drawer__title { font-size: var(--font-heading-3); margin: 0; text-transform: uppercase; letter-spacing: 0.1em; }
  .cart-drawer__close { background: none; border: none; color: var(--text-primary); cursor: pointer; }
  
  .cart-drawer__items {
    flex: 1; overflow-y: auto; padding: var(--space-24);
  }
  .cart-drawer__item {
    display: flex; gap: var(--space-16); margin-bottom: var(--space-24); padding-bottom: var(--space-24);
    border-bottom: 1px solid var(--border-subtle);
  }
  .cart-drawer__item-img {
    width: 80px; height: 100px; object-fit: cover; background: var(--bg-secondary); border-radius: 2px;
  }
  .cart-drawer__item-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
  .cart-drawer__item-title { font-size: var(--font-body-small); font-weight: bold; margin-bottom: 4px; display: block; color: var(--text-primary); text-decoration: none; }
  .cart-drawer__item-variant { font-size: 10px; color: var(--text-secondary); margin-bottom: 8px; text-transform: uppercase; }
  
  .cart-drawer__qty {
    display: inline-flex; border: 1px solid var(--border-subtle); align-items: center; border-radius: 2px;
  }
  .cart-drawer__qty button { background: none; border: none; color: inherit; padding: 4px 8px; cursor: pointer; }
  .cart-drawer__qty input { width: 30px; text-align: center; background: none; border: none; color: inherit; font-size: 12px; }
  
  .cart-drawer__remove { font-size: 10px; text-decoration: underline; color: var(--text-secondary); cursor: pointer; border: none; background: none; padding: 0; margin-top: 8px; text-align: left; }
  
  .cart-drawer__footer {
    padding: var(--space-24); border-top: 1px solid var(--border-subtle); background: var(--bg-secondary);
  }
  .cart-drawer__subtotal { display: flex; justify-content: space-between; margin-bottom: var(--space-16); font-size: var(--font-heading-3); }
  
  .cart-drawer__empty {
    text-align: center; padding-top: var(--space-64); color: var(--text-secondary);
  }
</style>

<div class="cart-drawer__overlay" id="CartDrawerOverlay"></div>
<div id="CartDrawer" data-section-id="{{ section.id }}">
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">Loadout <span id="CartDrawerCount">({{ cart.item_count }})</span></h2>
    <button class="cart-drawer__close" id="CartDrawerClose" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="cart-drawer__items" id="CartDrawerItems">
    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items -%}
        <div class="cart-drawer__item" data-key="{{ item.key }}">
          {%- if item.image -%}
            <img src="{{ item.image | image_url: width: 160 }}" class="cart-drawer__item-img" alt="{{ item.title | escape }}" width="{{ item.image.width }}" height="{{ item.image.height }}">
          {%- else -%}
            <div class="cart-drawer__item-img"></div>
          {%- endif -%}
          <div class="cart-drawer__item-info">
            <div>
              <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title }}</a>
              <div class="cart-drawer__item-variant">{{ item.variant.title }}</div>
              <div style="font-size: 12px;">{{ item.final_line_price | money }}</div>
            </div>
            <div>
              <div class="cart-drawer__qty">
                <button type="button" class="js-cd-qty" data-action="minus" data-key="{{ item.key }}">&minus;</button>
                <input type="number" value="{{ item.quantity }}" readonly>
                <button type="button" class="js-cd-qty" data-action="plus" data-key="{{ item.key }}">&plus;</button>
              </div>
              <button type="button" class="cart-drawer__remove js-cd-remove" data-key="{{ item.key }}">Remove</button>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="cart-drawer__empty">
        <p>Your loadout is currently empty.</p>
        <button class="btn-primary" style="margin-top: 16px;" onclick="document.getElementById('CartDrawerClose').click()">Continue Shopping</button>
      </div>
    {%- endif -%}
  </div>

  <div class="cart-drawer__footer">
    <div class="cart-drawer__subtotal">
      <span>Subtotal</span>
      <span id="CartDrawerTotal">{{ cart.total_price | money }}</span>
    </div>
    <p style="font-size: 10px; color: var(--text-secondary); margin-bottom: 16px;">Taxes and shipping calculated at checkout.</p>
    <div style="display: flex; gap: 8px;">
      <a href="{{ routes.cart_url }}" class="btn-secondary" style="flex: 1; text-align: center;">View Cart</a>
      <form action="{{ routes.cart_url }}" method="post" style="flex: 1;">
        <button type="submit" name="checkout" class="btn-primary" style="width: 100%;" {% if cart.item_count == 0 %}disabled{% endif %}>Checkout</button>
      </form>
    </div>
  </div>
</div>

<script>
class AeridianCartDrawer {
  constructor() {
    this.drawer = document.getElementById('CartDrawer');
    this.overlay = document.getElementById('CartDrawerOverlay');
    this.closeBtn = document.getElementById('CartDrawerClose');
    
    if (!this.drawer) return;
    this.bindEvents();
  }

  bindEvents() {
    this.closeBtn.addEventListener('click', () => this.close());
    this.overlay.addEventListener('click', () => this.close());
    
    // Listen to global cart add
    this._globalCartHandler = () => {
      this.refreshCart().then(() => this.open());
    };
    window.addEventListener('aeridian:cart-updated', this._globalCartHandler);

    // Delegate clicks for qty & remove
    this.drawer.addEventListener('click', (e) => {
      if (e.target.classList.contains('js-cd-qty')) {
        const action = e.target.dataset.action;
        const key = e.target.dataset.key;
        const input = e.target.parentElement.querySelector('input');
        let qty = parseInt(input.value, 10);
        if (action === 'plus') qty++;
        if (action === 'minus') qty--;
        this.updateItem(key, qty);
      }
      if (e.target.classList.contains('js-cd-remove')) {
        this.updateItem(e.target.dataset.key, 0);
      }
    });
  }

  open() {
    this.drawer.classList.add('is-open');
    this.overlay.classList.add('is-active');
    document.body.style.overflow = 'hidden';
  }

  close() {
    this.drawer.classList.remove('is-open');
    this.overlay.classList.remove('is-active');
    document.body.style.overflow = '';
  }

  async refreshCart() {
    try {
      const res = await fetch('/?section_id=cart-drawer');
      const text = await res.text();
      const html = new DOMParser().parseFromString(text, 'text/html');
      
      const newDrawer = html.getElementById('CartDrawer');
      if (newDrawer) {
        document.getElementById('CartDrawerItems').innerHTML = newDrawer.querySelector('#CartDrawerItems').innerHTML;
        document.getElementById('CartDrawerTotal').innerHTML = newDrawer.querySelector('#CartDrawerTotal').innerHTML;
        document.getElementById('CartDrawerCount').innerHTML = newDrawer.querySelector('#CartDrawerCount').innerHTML;
        
        // Update checkout button state
        const checkoutBtn = this.drawer.querySelector('button[name="checkout"]');
        const newBtn = newDrawer.querySelector('button[name="checkout"]');
        if (checkoutBtn && newBtn) {
          if (newBtn.disabled) checkoutBtn.setAttribute('disabled', 'disabled');
          else checkoutBtn.removeAttribute('disabled');
        }
        
        // Update header cart count badge if it exists
        const headerCounts = document.querySelectorAll('.cart-count-badge');
        headerCounts.forEach(el => {
          const match = newDrawer.querySelector('#CartDrawerCount').innerHTML.match(/\((\d+)\)/);
          if (match) el.textContent = match[1];
        });
      }
    } catch (err) {
      console.error('Cart Drawer refresh failed:', err);
    }
  }

  async updateItem(key, quantity) {
    try {
      this.drawer.style.opacity = '0.5';
      this.drawer.style.pointerEvents = 'none';
      
      await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity })
      });
      
      await this.refreshCart();
    } catch (err) {
      console.error('Cart Drawer update failed:', err);
    } finally {
      this.drawer.style.opacity = '1';
      this.drawer.style.pointerEvents = 'auto';
    }
  }
  destroy() {
    if (this._globalCartHandler) {
      window.removeEventListener('aeridian:cart-updated', this._globalCartHandler);
    }
  }

  reInit() {
    this.destroy();
    this.bindEvents();
  }
}

if (!window.AERIDIAN) window.AERIDIAN = { Modules: {} };
if (!window.AERIDIAN.Modules.CartDrawer) {
  window.AERIDIAN.Modules.CartDrawer = new AeridianCartDrawer();
  document.addEventListener('DOMContentLoaded', () => {
    window.AERIDIAN.Utils?.log('CartDrawer', 'initialized');
  });
} else {
  // If re-rendered by Shopify
  window.AERIDIAN.Modules.CartDrawer = new AeridianCartDrawer();
}
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
