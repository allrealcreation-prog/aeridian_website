{% if product %}
  <div class="wishlist-card-wrapper" style="position: relative;" data-handle="{{ product.handle }}">
    {% render 'product-card', product: product %}
    <button class="pc-action-btn wishlist-card__remove" aria-label="Remove from wishlist" onclick="removeFromWishlist('{{ product.handle }}', this)" style="position: absolute; top: var(--space-16); right: var(--space-16); width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center; z-index: 10;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
{% endif %}
