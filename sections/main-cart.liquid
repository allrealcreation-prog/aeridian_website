<div class="container container--narrow" style="padding-top: var(--space-120); padding-bottom: var(--space-120);">
  <h1 style="margin-bottom: var(--space-64); text-align: center;">Your Loadout</h1>
  
  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <div class="cart-items" style="margin-bottom: var(--space-64);">
        {%- for item in cart.items -%}
          <div class="cart-item" style="display: flex; gap: var(--space-24); margin-bottom: var(--space-32); padding-bottom: var(--space-32); border-bottom: 1px solid var(--border-subtle);">
            <div class="cart-item__media" style="width: 120px;">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 300 }}" alt="{{ item.title | escape }}" style="width: 100%; height: auto; object-fit: cover;" width="{{ item.image.width }}" height="{{ item.image.height }}">
              {%- endif -%}
            </div>
            <div class="cart-item__details" style="flex: 1;">
              <h3 style="margin-bottom: var(--space-8);"><a href="{{ item.url }}" style="color: inherit; text-decoration: none;">{{ item.product.title }}</a></h3>
              <p style="color: var(--text-secondary); font-size: var(--font-caption); margin-bottom: var(--space-16);">{{ item.variant.title }}</p>
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <div class="quantity-selector" style="display: flex; border: 1px solid var(--border-subtle);">
                  <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" style="padding: 8px 12px; color: inherit; text-decoration: none;">-</a>
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width: 40px; text-align: center; background: transparent; border: none; color: inherit;">
                  <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" style="padding: 8px 12px; color: inherit; text-decoration: none;">+</a>
                </div>
                <div class="cart-item__price">{{ item.final_line_price | money }}</div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
      
      <div class="cart-footer" style="text-align: right;">
        <h3 style="margin-bottom: var(--space-24);">Subtotal: {{ cart.total_price | money }}</h3>
        <p style="color: var(--text-secondary); margin-bottom: var(--space-32); font-size: var(--font-caption);">Taxes and shipping calculated at checkout.</p>
        <button type="submit" name="checkout" class="btn-primary" style="width: 100%; max-width: 300px;">Checkout</button>
      </div>
    </form>
  {%- else -%}
    <div style="text-align: center;">
      <p style="color: var(--text-secondary); margin-bottom: var(--space-32);">Your loadout is currently empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn-primary">Explore Equipment</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart Experience",
  "settings": []
}
{% endschema %}
