<style>
  .pdp-storytelling {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    overflow: hidden;
    padding: var(--space-80) var(--space-24);
  }

  .pdp-story-bg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 1;
  }
  .pdp-story-bg img {
    width: 100%; height: 100%; object-fit: cover; opacity: 0.4;
  }
  
  /* Gradient blend into next section */
  .pdp-story-bg::after {
    content: ''; position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(to bottom, var(--bg-primary) 0%, transparent 20%, transparent 80%, var(--bg-primary) 100%);
  }

  .pdp-story-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
  }

  .pdp-story-title {
    font-size: var(--font-display-m);
    margin-bottom: var(--space-24);
    letter-spacing: -0.02em;
  }

  .pdp-story-text {
    font-size: var(--font-body-large);
    color: var(--text-secondary);
    line-height: 1.6;
  }
</style>

<section class="pdp-storytelling" data-section-id="{{ section.id }}">
  <div class="pdp-story-bg">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="" loading="lazy" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}">
    {%- else -%}
      <!-- Default Cinematic Glow if no image provided -->
      <div style="width: 100%; height: 100%; background: radial-gradient(closest-side, var(--glow-color) 0%, transparent 100%); opacity: 0.3;"></div>
    {%- endif -%}
  </div>

  <div class="pdp-story-content" data-scroll-reveal>
    <h2 class="pdp-story-title">{{ section.settings.heading | default: 'Materials & Craftsmanship' }}</h2>
    <div class="pdp-story-text">
      {{ section.settings.text | default: 'Constructed with uncompromising precision. Every stitch and seam is engineered for future environments, blending advanced technical textiles with a brutalist, weightless aesthetic.' }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Storytelling",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Cinematic Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Materials & Craftsmanship"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Narrative Text",
      "default": "Constructed with uncompromising precision."
    }
  ]
}
{% endschema %}
