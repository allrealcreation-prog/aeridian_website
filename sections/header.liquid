<style>
  /* Base Header Styles */
  .global-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-base) var(--ease-luxury);
  }

  .header-logo__svg {
    width: 200px;
    height: auto;
    display: block;
    color: var(--text-primary);
  }

  .global-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(20px);
    z-index: -1;
    opacity: 0;
    will-change: opacity;
    pointer-events: none;
    transition: opacity var(--duration-base) var(--ease-luxury);
  }

  .global-header.is-scrolled {
    border-bottom: var(--border-subtle);
  }

  .global-header.is-scrolled::before {
    opacity: 1;
  }

  /* Header Layout */
  .header-wrapper {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 80px; /* Base height */
    padding: 0 var(--space-24);
    max-width: var(--container-large);
    margin: 0 auto;
  }

  /* Logo Area */
  .header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header-logo__text {
    font-family: var(--font-display);
    font-size: var(--font-heading-3);
    letter-spacing: 0.1em;
    font-weight: 500;
    text-transform: uppercase;
  }

  /* Desktop Nav Container */
  .header-nav--left,
  .header-nav--right {
    display: flex;
    align-items: center;
    gap: var(--space-32);
  }
  .header-nav--left {
    justify-content: flex-start;
  }
  .header-nav--right {
    justify-content: flex-end;
  }

  /* Right Icons */
  .header-icons--right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
  }

  .header-icon {
    background: none;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    transition: opacity var(--duration-fast) var(--ease-luxury);
  }

  .header-icon:hover {
    opacity: 0.7;
  }

  .header-icon svg {
    width: 24px;
    height: 24px;
  }
  
  .header-utilities {
    display: flex;
    gap: var(--space-24);
    align-items: center;
    border-left: 1px solid var(--border-subtle);
    padding-left: var(--space-24);
    height: 24px;
  }

  /* Mobile Toggle */
  .header-mobile-toggle {
    display: none;
  }

  @media screen and (max-width: 1024px) {
    .header-nav--left,
    .header-nav--right {
      display: none !important; /* Hide desktop nav */
    }
    .header-mobile-toggle {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      background: none;
      border: none;
      color: var(--text-primary);
      cursor: pointer;
      min-width: 44px;
      min-height: 44px;
    }
    .header-logo {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    .header-wrapper {
      display: flex;
      align-items: center;
      height: 64px;
      padding: 0 var(--space-16);
      width: 100%;
    }
    .header-utilities {
      flex: 1;
      justify-content: flex-end;
      gap: var(--space-16);
      padding-left: 0;
      border-left: none;
    }
  }

  @media screen and (max-width: 767px) {
    .header-icon--theme,
    .header-icon--account,
    .header-icon--wishlist {
      display: none !important;
    }
    .header-logo__svg {
      width: 120px; /* Aggressively scaled down for mobile to prevent overlap */
    }
  }
</style>

<header id="GlobalHeader" class="global-header {% if section.settings.enable_transparent %}is-transparent{% else %}is-scrolled{% endif %}" role="banner">
  <div class="header-wrapper">
    
    <!-- Mobile Hamburger -->
    <button class="header-mobile-toggle" aria-expanded="false" aria-controls="MobileNavDrawer" aria-label="Open Navigation" onclick="toggleMobileNav(this)">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 7H20M4 12H20M4 17H20" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Desktop Navigation (Left) -->
    <div class="header-nav--left">
      {% render 'header-desktop-nav', menu: section.settings.desktop_menu, position: 'left' %}
    </div>

    <!-- Logo (Center) -->
    <a href="{{ routes.root_url }}" class="header-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" width="{{ section.settings.logo.width }}" height="{{ section.settings.logo.height }}" style="max-width: {{ section.settings.logo_width }}px;">
      {%- else -%}
        {% render 'icon-wordmark', class: 'header-logo__svg' %}
      {%- endif -%}
    </a>

    <!-- Icons (Right) -->
    <div class="header-icons--right">
      
      <!-- Split Nav Right Side -->
      <div class="header-nav--right">
        {% render 'header-desktop-nav', menu: section.settings.desktop_menu, position: 'right' %}
      </div>

      <!-- Theme Controls & Utilities -->
      <div class="header-utilities">
        
        <button id="ThemeToggle" class="header-icon header-icon--theme js-magnetic" data-magnetic-intensity="0.3" aria-label="Toggle Theme" title="Toggle Theme">
          <!-- Sun (Light Mode) -->
          <svg class="theme-icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display: none;"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <!-- Moon (Dark Mode) -->
          <svg class="theme-icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>

        <button class="header-icon header-icon--search js-magnetic" data-magnetic-intensity="0.3" aria-label="Search" onclick="toggleSearch()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 19C15.4183 19 19 15.4183 19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 21L16.65 16.65" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        
        <a href="{{ routes.account_url }}" class="header-icon header-icon--account js-magnetic" data-magnetic-intensity="0.3" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21V19C20 17.9391 19.5786 16.9217 18.8284 16.1716C18.0783 15.4214 17.0609 15 16 15H8C6.93913 15 5.92172 15.4214 5.17157 16.1716C4.42143 16.9217 4 17.9391 4 19V21" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 11C14.2091 11 16 9.20914 16 7C16 4.79086 14.2091 3 12 3C9.79086 3 8 4.79086 8 7C8 9.20914 9.79086 11 12 11Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>

        <button class="header-icon header-icon--wishlist js-magnetic" data-magnetic-intensity="0.3" aria-label="Wishlist" onclick="toggleWishlist()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <a href="{{ routes.cart_url }}" class="header-icon header-icon--cart js-magnetic" data-magnetic-intensity="0.3" aria-label="Cart" style="display: flex; align-items: center; gap: 8px; text-decoration: none;">
          <!-- Premium Geometric Shopping Tote -->
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M5 8h14v12H5z" stroke-linecap="square" />
            <path d="M9 8V5h6v3" stroke-linecap="square" />
          </svg>
          <span id="CartCount" class="cart-count-badge" style="font-size: var(--font-body-small); font-weight: 500;">{{ cart.item_count | default: 0 }}</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Mega Menu Dropdown -->
  {% render 'header-mega-menu' %}
</header>

<!-- Global Drawers & Overlays -->
{% render 'header-mobile-nav', menu: section.settings.mobile_menu %}
{% render 'search-overlay' %}
<!-- Cart Drawer is injected as a section in theme.liquid -->
{% render 'wishlist-drawer' %}

<script>
  // Scroll Logic for Header
  (function(){
    const header = document.getElementById('GlobalHeader');
    const isTransparentEnabled = {{ section.settings.enable_transparent | json }};
    
    if(!isTransparentEnabled) return;

    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.remove('is-transparent');
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
        header.classList.add('is-transparent');
      }
    }, { passive: true });
  })();

  // Global Toggle Functions
  function toggleMobileNav(btn) { document.getElementById('MobileNavDrawer').classList.add('is-open'); document.body.style.overflow = 'hidden'; if(btn) btn.setAttribute('aria-expanded', 'true'); }
  function toggleSearch() { document.getElementById('SearchOverlay').classList.add('is-open'); document.body.style.overflow = 'hidden'; document.getElementById('SearchInput').focus(); }
  function toggleWishlist() { document.getElementById('WishlistDrawer').classList.add('is-open'); document.body.style.overflow = 'hidden'; }

  // Theme Toggle Function
  function toggleTheme() {
    const isLight = document.documentElement.getAttribute('data-theme') === 'light';
    const newTheme = isLight ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('aeridian_theme', newTheme);
    updateThemeIcon(newTheme);
  }

  function updateThemeIcon(theme) {
    const lightIcon = document.querySelector('.theme-icon-light');
    const darkIcon = document.querySelector('.theme-icon-dark');
    if(lightIcon && darkIcon) {
      if(theme === 'light') {
        lightIcon.style.display = 'block';
        darkIcon.style.display = 'none';
      } else {
        lightIcon.style.display = 'none';
        darkIcon.style.display = 'block';
      }
    }
  }

  // Initialize correct icon on load
  document.addEventListener('DOMContentLoaded', () => {
    updateThemeIcon(document.documentElement.getAttribute('data-theme') || 'dark');
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo Width",
      "default": 150
    },
    {
      "type": "checkbox",
      "id": "enable_transparent",
      "label": "Enable transparent header",
      "info": "Header becomes transparent when at the top of the page.",
      "default": true
    },
    {
      "type": "link_list",
      "id": "desktop_menu",
      "label": "Desktop Navigation Menu"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile Navigation Menu"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "Mega Menu Panel",
      "settings": [
        {
          "type": "text",
          "id": "trigger",
          "label": "Menu Item Trigger",
          "info": "Name of the top-level link that triggers this mega menu (e.g., 'Shop')"
        },
        {
          "type": "image_picker",
          "id": "campaign_image",
          "label": "Campaign Image"
        },
        {
          "type": "text",
          "id": "campaign_title",
          "label": "Campaign Title"
        }
      ]
    }
  ]
}
{% endschema %}
