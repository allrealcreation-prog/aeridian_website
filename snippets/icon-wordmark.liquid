{%- comment -%}
  AERIDIAN Official Wordmark SVG
  Inline component for pixel-perfect scaling and theme inversion.
{%- endcomment -%}
<svg class="{{ class | default: 'icon-wordmark' }}" viewBox="0 0 1700.79 277.95" fill="currentColor" aria-hidden="true" focusable="false" role="presentation" style="{{ style }}">
  <defs>
    <style>
      .wordmark-text {
        font-family: var(--font-display);
        font-size: 245.11px;
        fill: currentColor;
      }
      .ws-1 { letter-spacing: -.02em; }
      .ws-2 { letter-spacing: 0em; }
      .ws-4 { letter-spacing: -.03em; }
      .ws-5 { letter-spacing: -.03em; }
    </style>
  </defs>
  <text class="wordmark-text" transform="translate(0 208.34)">
    <tspan class="ws-5" x="0" y="0">A</tspan>
    <tspan class="ws-1" x="278.19" y="0">E</tspan>
    <tspan class="ws-2" x="520.12" y="0">R</tspan>
    <tspan x="764.49" y="0">ID</tspan>
    <tspan class="ws-4" x="1101.01" y="0">I</tspan>
    <tspan class="ws-1" x="1183.37" y="0">A</tspan>
    <tspan x="1464.02" y="0">N</tspan>
  </text>
</svg>
