<div id="WishlistDrawer" class="drawer-container" role="dialog" aria-modal="true">
  <div class="drawer-overlay" onclick="closeWishlist()"></div>
  <div class="drawer">
    <div class="drawer__header">
      <h2 class="drawer__title">Wishlist</h2>
      <button class="drawer__close" aria-label="Close Wishlist" onclick="closeWishlist()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M18 6L6 18M6 6L18 18" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="drawer__content">
      <div class="empty-state">
        <p>No items in your wishlist.</p>
      </div>
    </div>

    <div class="drawer__footer">
      <button class="btn" onclick="closeWishlist()">Continue Shopping</button>
    </div>
  </div>
</div>

<script>
  function closeWishlist() {
    document.getElementById('WishlistDrawer').classList.remove('is-open');
    document.body.style.overflow = '';
  }
</script>
