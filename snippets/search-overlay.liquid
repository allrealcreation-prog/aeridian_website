<style>
  .search-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: rgba(5, 5, 5, 0.98);
    backdrop-filter: blur(20px);
    z-index: 1200;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-base) var(--ease-luxury), visibility var(--duration-base);
    display: flex;
    flex-direction: column;
  }

  .search-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .search-overlay__header {
    padding: var(--space-32) var(--space-48);
    display: flex;
    justify-content: flex-end;
  }

  .search-overlay__close {
    background: none;
    border: none;
    color: var(--color-primary-pure-white);
    padding: var(--space-8);
    cursor: pointer;
  }

  .search-overlay__content {
    flex: 1;
    max-width: var(--container-standard);
    width: 100%;
    margin: 0 auto;
    padding: var(--space-64) var(--space-24);
    display: flex;
    flex-direction: column;
  }

  .search-overlay__form {
    position: relative;
    width: 100%;
    margin-bottom: var(--space-48);
  }

  .search-overlay__input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 2px solid var(--color-primary-carbon);
    color: var(--color-primary-pure-white);
    font-size: var(--font-heading-2);
    font-family: var(--font-body);
    padding: var(--space-16) 0;
    outline: none;
    transition: border-color var(--duration-fast);
  }

  .search-overlay__input:focus {
    border-bottom-color: var(--color-accent-atmospheric);
  }

  .search-overlay__input::placeholder {
    color: var(--color-secondary-steel);
  }

  .search-overlay__submit {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--color-primary-pure-white);
    cursor: pointer;
  }

  .search-overlay__suggestions {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-64);
  }

  .search-overlay__title {
    font-size: var(--font-caption);
    color: var(--color-secondary-steel);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caption);
    margin-bottom: var(--space-24);
  }

  .search-overlay__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .search-overlay__link {
    color: var(--color-primary-soft-white);
    font-size: var(--font-body-large);
    transition: color var(--duration-fast);
  }

  .search-overlay__link:hover {
    color: var(--color-primary-pure-white);
  }

  @media screen and (max-width: 768px) {
    .search-overlay__header {
      padding: var(--space-16) var(--space-16);
    }
    .search-overlay__suggestions {
      grid-template-columns: 1fr;
    }
    .search-overlay__input {
      font-size: var(--font-heading-3);
    }
  }
</style>

<div id="SearchOverlay" class="search-overlay" role="dialog" aria-modal="true">
  <div class="search-overlay__header">
    <button class="search-overlay__close" aria-label="Close Search" onclick="closeSearch()">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 6L6 18M6 6L18 18" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="search-overlay__content">
    <form action="{{ routes.search_url }}" method="get" class="search-overlay__form" role="search">
      <input type="hidden" name="type" value="product">
      <input 
        id="SearchInput"
        type="search" 
        name="q" 
        class="search-overlay__input" 
        placeholder="SEARCH AERIDIAN..."
        autocomplete="off"
      >
      <button type="submit" class="search-overlay__submit" aria-label="Submit Search">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 19C15.4183 19 19 15.4183 19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 21L16.65 16.65" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </form>

    <div class="search-overlay__suggestions">
      <div>
        <div class="search-overlay__title">Suggested Searches</div>
        <ul class="search-overlay__list">
          <li><a href="{{ routes.search_url }}?q=jacket" class="search-overlay__link">Technical Jackets</a></li>
          <li><a href="{{ routes.search_url }}?q=cargo" class="search-overlay__link">Cargo Pants</a></li>
          <li><a href="{{ routes.search_url }}?q=essentials" class="search-overlay__link">Essentials</a></li>
        </ul>
      </div>
    </div>
  </div>
</div>

<script>
  function closeSearch() {
    document.getElementById('SearchOverlay').classList.remove('is-open');
    document.body.style.overflow = '';
  }

  // Predictive Search API Integration
  document.addEventListener('DOMContentLoaded', () => {
    let debounceTimer;
    const searchInput = document.getElementById('SearchInput');
    const suggestionsContainer = document.querySelector('.search-overlay__suggestions');
    
    // Cache the default state html

    // Cache the default state node
    const defaultStateNodes = [];
    if (suggestionsContainer) {
      Array.from(suggestionsContainer.childNodes).forEach(node => {
        defaultStateNodes.push(node.cloneNode(true));
      });
    }

    if (searchInput && suggestionsContainer) {
      searchInput.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        const query = e.target.value.trim();
        
        if (query.length === 0) {

          suggestionsContainer.textContent = '';
          defaultStateNodes.forEach(node => {
            suggestionsContainer.appendChild(node.cloneNode(true));
          });
          return;
        }

        suggestionsContainer.textContent = '';
        const detectingDiv = document.createElement('div');
        detectingDiv.className = 'search-overlay__title';
        detectingDiv.style.color = 'var(--accent-color)';
        detectingDiv.textContent = 'Detecting Signals...';
        suggestionsContainer.appendChild(detectingDiv);

        debounceTimer = setTimeout(() => {
          fetch(`/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product,article,collection&resources[options][unavailable_products]=last`)
            .then(res => res.json())
            .then(data => {
              const products = data.resources.results.products || [];
              const articles = data.resources.results.articles || [];
              const collections = data.resources.results.collections || [];

              suggestionsContainer.textContent = '';
              const wrapper = document.createElement('div');
              wrapper.style.display = 'grid';
              wrapper.style.gridTemplateColumns = '1fr 2fr';
              wrapper.style.gap = 'var(--space-64)';
              wrapper.style.width = '100%';

              if (products.length === 0 && articles.length === 0 && collections.length === 0) {
                const noCoords = document.createElement('div');
                noCoords.className = 'search-overlay__title';
                noCoords.textContent = `No coordinates found for "${query}".`;
                wrapper.appendChild(noCoords);
              } else {
                // Products
                if (products.length > 0) {
                  const prodDiv = document.createElement('div');

                  const prodTitle = document.createElement('div');
                  prodTitle.className = 'search-overlay__title';
                  prodTitle.textContent = 'Artifacts';
                  prodDiv.appendChild(prodTitle);

                  const prodList = document.createElement('ul');
                  prodList.className = 'search-overlay__list';

                  products.slice(0, 4).forEach(p => {
                    const li = document.createElement('li');
                    const a = document.createElement('a');
                    a.href = p.url;
                    a.className = 'search-overlay__link';
                    a.style.display = 'flex';
                    a.style.alignItems = 'center';
                    a.style.gap = '16px';

                    if (p.image) {
                      const img = document.createElement('img');
                      img.src = p.image;
                      img.width = 40;
                      img.height = 50;
                      img.style.objectFit = 'cover';
                      img.style.borderRadius = '2px';
                      a.appendChild(img);
                    }

                    const spanContainer = document.createElement('span');

                    const titleText = document.createTextNode(p.title + ' ');
                    spanContainer.appendChild(titleText);

                    const br = document.createElement('br');
                    spanContainer.appendChild(br);

                    const priceSpan = document.createElement('span');
                    priceSpan.style.fontSize = '10px';
                    priceSpan.style.color = 'var(--text-secondary)';
                    priceSpan.textContent = p.price;
                    spanContainer.appendChild(priceSpan);

                    a.appendChild(spanContainer);
                    li.appendChild(a);
                    prodList.appendChild(li);
                  });
                  prodDiv.appendChild(prodList);
                  wrapper.appendChild(prodDiv);
                }
                
                // Collections & Articles
                if (collections.length > 0 || articles.length > 0) {
                  const rightCol = document.createElement('div');

                  if (collections.length > 0) {
                    const colTitle = document.createElement('div');
                    colTitle.className = 'search-overlay__title';
                    colTitle.textContent = 'Categories';
                    rightCol.appendChild(colTitle);

                    const colList = document.createElement('ul');
                    colList.className = 'search-overlay__list';
                    colList.style.marginBottom = '32px';

                    collections.slice(0, 2).forEach(c => {
                      const li = document.createElement('li');
                      const a = document.createElement('a');
                      a.href = c.url;
                      a.className = 'search-overlay__link';
                      a.textContent = c.title;
                      li.appendChild(a);
                      colList.appendChild(li);
                    });
                    rightCol.appendChild(colList);
                  }

                  if (articles.length > 0) {
                    const artTitle = document.createElement('div');
                    artTitle.className = 'search-overlay__title';
                    artTitle.textContent = 'Journal';
                    rightCol.appendChild(artTitle);

                    const artList = document.createElement('ul');
                    artList.className = 'search-overlay__list';

                    articles.slice(0, 2).forEach(a => {
                      const li = document.createElement('li');
                      const link = document.createElement('a');
                      link.href = a.url;
                      link.className = 'search-overlay__link';
                      link.textContent = a.title;
                      li.appendChild(link);
                      artList.appendChild(li);
                    });
                    rightCol.appendChild(artList);
                  }

                  wrapper.appendChild(rightCol);
                }
              }

              suggestionsContainer.appendChild(wrapper);
            })
            .catch(err => {
              console.error('Search error:', err);
              suggestionsContainer.textContent = '';
              const errDiv = document.createElement('div');
              errDiv.className = 'search-overlay__title';
              errDiv.textContent = 'Error establishing signal.';
              suggestionsContainer.appendChild(errDiv);
            });
        }, 300); // 300ms debounce
      });
    }
  });
</script>
